@page
@model TwiceTasks.Areas.Identity.Pages.Account.Manage.IndexModel
@{
    ViewData["Title"] = "Perfil";
    ViewData["ActivePage"] = ManageNavPages.Index;
    Layout = "_Layout";
}

<partial name="_StatusMessage" model="Model.StatusMessage" />

<div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-3">
    <div>
        <div class="tt-form-section-title">Perfil</div>
        <div class="tt-form-section-sub">Actualiza tu información básica y cómo te identificas en TwiceTasks.</div>
    </div>
</div>

<form id="profile-form" method="post" class="needs-validation" novalidate>
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

    <div class="row g-3">
        <div class="col-12 col-lg-6">
            <label class="form-label fw-semibold">Usuario</label>
            <input class="form-control" value="@Model.Username" disabled />
            <div class="form-text">Tu nombre de usuario (solo lectura).</div>
        </div>

        <div class="col-12 col-lg-6">
            <label asp-for="Input.PhoneNumber" class="form-label fw-semibold"></label>
            <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Ej: +34 600 000 000" />
            <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
            <div class="form-text">Se usa para recuperación y seguridad (si está configurado).</div>
        </div>

        <div class="col-12 col-lg-6">
            <label asp-for="Input.DisplayName" class="form-label fw-semibold"></label>
            <input asp-for="Input.DisplayName" class="form-control" placeholder="Cómo quieres que te llamemos" />
            <span asp-validation-for="Input.DisplayName" class="text-danger small"></span>
        </div>

        <div class="col-12 col-lg-6">
            <label asp-for="Input.AvatarUrl" class="form-label fw-semibold"></label>
            <input asp-for="Input.AvatarUrl" class="form-control" placeholder="https://..." />
            <span asp-validation-for="Input.AvatarUrl" class="text-danger small"></span>
            <div class="form-text">URL de una imagen (opcional). Se mostrará en futuras mejoras del perfil.</div>
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary btn-lg px-4">Guardar cambios</button>
        <a class="btn btn-outline-secondary btn-lg" asp-area="" asp-controller="Home" asp-action="Index">Volver</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
