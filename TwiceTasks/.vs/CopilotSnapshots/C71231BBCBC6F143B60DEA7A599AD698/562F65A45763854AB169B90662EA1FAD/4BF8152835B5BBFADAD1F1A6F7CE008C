@{
    Layout = "/Views/Shared/_Layout.cshtml";
}

<style>
    /* ===== Manage (Account) redesign ===== */
    .tt-manage-shell{
        padding: 28px 0 54px;
    }
    .tt-manage-title{
        font-size: clamp(1.6rem, 1.2rem + 1vw, 2.3rem);
        font-weight: 800;
        letter-spacing: -.02em;
    }
    .tt-manage-sub{
        color: color-mix(in srgb, var(--text) 65%, transparent);
    }

    .tt-manage-card{
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 22px;
        box-shadow: 0 18px 50px rgba(0,0,0,.14);
    }

    .tt-manage-nav{
        padding: 18px;
    }
    .tt-manage-nav .nav-link{
        border-radius: 14px;
        padding: 12px 12px;
        color: color-mix(in srgb, var(--text) 80%, transparent);
        border: 1px solid transparent;
        background: color-mix(in srgb, var(--card) 85%, transparent);
    }
    .tt-manage-nav .nav-link:hover{
        border-color: color-mix(in srgb, var(--border) 80%, transparent);
        color: var(--text);
    }
    .tt-manage-nav .nav-link.active{
        background: color-mix(in srgb, var(--link) 14%, var(--card));
        border-color: color-mix(in srgb, var(--link) 35%, var(--border));
        color: var(--text);
        font-weight: 700;
    }

    .tt-manage-avatar{
        width: 44px;
        height: 44px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: color-mix(in srgb, var(--link) 14%, var(--card));
        border: 1px solid var(--border);
    }

    .tt-form-card{
        padding: 18px;
    }

    @media (min-width: 992px){
        .tt-form-card{
            padding: 26px 28px;
        }
    }

    /* Bigger, cleaner form controls */
    .tt-form-card .form-control,
    .tt-form-card .form-select{
        border-radius: 14px;
        border: 1px solid var(--border);
        background: color-mix(in srgb, var(--card) 92%, transparent);
        color: var(--text);
        padding: .85rem .95rem;
        font-size: 1.05rem;
    }
    .tt-form-card .form-control:focus,
    .tt-form-card .form-select:focus{
        border-color: color-mix(in srgb, var(--link) 60%, var(--border));
        box-shadow: 0 0 0 .25rem color-mix(in srgb, var(--link) 20%, transparent);
    }
    .tt-form-card .btn{
        border-radius: 14px;
        padding: .85rem 1rem;
        font-weight: 700;
    }
    .tt-form-card .form-text{
        color: color-mix(in srgb, var(--text) 65%, transparent);
    }
    .tt-form-section-title{
        font-size: clamp(1.15rem, 1.05rem + .4vw, 1.45rem);
        font-weight: 800;
        letter-spacing: -.01em;
        margin-bottom: 6px;
    }
    .tt-form-section-sub{
        color: color-mix(in srgb, var(--text) 65%, transparent);
        margin-bottom: 18px;
    }
</style>

<div class="container-xxl tt-manage-shell">
    <div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-2 mb-4">
        <div>
            <div class="tt-manage-title">Cuenta</div>
            <div class="tt-manage-sub">Gestiona tu perfil, seguridad y datos.</div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-lg-4 col-xl-3">
            <div class="tt-manage-card">
                <partial name="_ManageNav" />
            </div>
        </div>
        <div class="col-12 col-lg-8 col-xl-9">
            <div class="tt-manage-card tt-form-card">
                @RenderBody()
            </div>
        </div>
    </div>
</div>

@RenderSection("Scripts", required: false)
