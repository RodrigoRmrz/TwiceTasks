@model TwiceTasks.Models.Page

@{
    var workspaces = ViewBag.Workspaces as List<TwiceTasks.Models.Workspace> ?? new();
    ViewData["Title"] = "Nueva nota";
}

<div class="container-xxl py-4">
    <div class="card shadow-sm rounded-4" style="background: var(--card-bg); border-color: var(--border);">
        <div class="card-body p-4 p-lg-5">
            <div class="d-flex flex-column flex-md-row align-items-md-end justify-content-between gap-3 mb-4">
                <div>
                    <h2 class="fw-bold m-0" style="letter-spacing:-.02em;"><i class="bi bi-journal-plus me-2"></i>Nueva nota</h2>
                    <p class="text-muted mb-0">Crea una nota y asígnala a un workspace si quieres.</p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                    <i class="bi bi-arrow-left me-2"></i>Volver
                </a>
            </div>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    <div class="col-12 col-lg-8">
                        <label class="form-label fw-semibold">Título</label>
                        <input asp-for="Title" class="form-control form-control-lg" placeholder="Ej: Plan de Marketing Q1" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                    <div class="col-12 col-lg-4">
                        <label class="form-label fw-semibold">Workspace</label>
                        <select asp-for="WorkspaceId" class="form-select form-select-lg">
                            <option value="">— Sin workspace —</option>
                            @foreach (var ws in workspaces)
                            {
                                <option value="@ws.Id">@ws.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Contenido</label>
                        <textarea asp-for="Content" class="form-control" rows="12" placeholder="Escribe aquí..."></textarea>
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2 mt-4">
                    <button class="btn btn-primary btn-lg" type="submit">
                        <i class="bi bi-check2-circle me-2"></i>Crear nota
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
