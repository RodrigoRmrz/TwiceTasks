@model IEnumerable<TwiceTasks.Models.Page>

@{
    var workspace = ViewBag.Workspace as TwiceTasks.Models.Workspace;
    var workspaces = ViewBag.Workspaces as List<TwiceTasks.Models.Workspace> ?? new();
    var unassigned = ViewBag.UnassignedPages as List<TwiceTasks.Models.Page> ?? new();
    var recentFiles = ViewBag.RecentFiles as List<TwiceTasks.Models.FileResource> ?? new();

    ViewData["Title"] = workspace != null ? $"Notas - {workspace.Name}" : "Notas";
    int? returnWsId = workspace?.Id;

    var notes = (workspace == null ? unassigned : (Model ?? Enumerable.Empty<TwiceTasks.Models.Page>()))
        .OrderByDescending(p => p.UpdatedAt)
        .ToList();

    var recentNotes = notes.Take(8).ToList();
}

<style>
    .notes-shell { max-width: 1700px; }
    .panel {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 18px;
        box-shadow: 0 10px 26px var(--shadow);
    }
    .panel-h {
        padding: 14px 16px;
        border-bottom: 1px solid var(--border);
    }
    .panel-b { padding: 14px 16px; }

    .ws-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 10px 12px;
        border-radius: 12px;
        text-decoration: none;
        color: var(--text);
        border: 1px solid transparent;
    }
    .ws-link:hover {
        background: rgba(255,255,255,.04);
        border-color: var(--border);
        color: var(--text);
    }
    .ws-link.active {
        border-color: var(--border);
        background: rgba(13,110,253,.10);
    }

    .note-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 16px;
        box-shadow: 0 6px 16px var(--shadow);
        transition: transform .16s ease, box-shadow .16s ease;
        height: 100%;
    }
    .note-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 14px 28px var(--shadow);
    }
    .note-title {
        font-weight: 800;
        letter-spacing: -0.02em;
        margin: 0;
        line-height: 1.2;
    }
    .note-snippet {
        color: var(--text-muted);
        opacity: .88;
        margin: 10px 0 0 0;
    }

    .mini-select {
        min-width: 180px;
    }

    @@media (max-width: 1200px) {
        .right-col { display: none; }
    }
</style>

<div class="container-xxl py-4 notes-shell">
    <div class="d-flex flex-column flex-md-row align-items-md-end justify-content-between gap-3 mb-4">
        <div>
            <h1 class="fw-bold m-0" style="letter-spacing:-.02em;">
                @(workspace != null ? workspace.Name : "Notas")
            </h1>
            <p class="text-muted mb-0">
                @(workspace != null ? "Tus notas dentro de este workspace." : "Tus notas sin workspace y un resumen rápido de tu contenido.")
            </p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary btn-lg" asp-controller="Pages" asp-action="Create" asp-route-workspaceId="@returnWsId">
                <i class="bi bi-plus-circle me-2"></i>Nueva nota
            </a>
            <a class="btn btn-outline-secondary btn-lg" asp-controller="Files" asp-action="Index">
                <i class="bi bi-folder me-2"></i>Archivos
            </a>
        </div>
    </div>

    <div class="row g-3 align-items-start">
        <!-- LEFT: Workspaces -->
        <div class="col-12 col-lg-3">
            <div class="panel">
                <div class="panel-h d-flex align-items-center justify-content-between">
                    <div class="fw-bold" style="letter-spacing:-.01em;">Workspaces</div>
                    <a class="btn btn-sm btn-outline-primary" asp-controller="Workspaces" asp-action="Create">
                        <i class="bi bi-plus"></i>
                    </a>
                </div>
                <div class="panel-b">
                    <div class="d-grid gap-2">
                        <a class="ws-link @(workspace == null ? "active" : "")" asp-controller="Pages" asp-action="Index">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-inbox"></i>
                                <span class="fw-semibold">Sin workspace</span>
                            </div>
                        </a>
                        @foreach (var ws in workspaces)
                        {
                            var isActive = workspace != null && workspace.Id == ws.Id;
                            <a class="ws-link @(isActive ? "active" : "")" asp-controller="Pages" asp-action="Index" asp-route-workspaceId="@ws.Id">
                                <div class="d-flex align-items-center gap-2" style="min-width:0;">
                                    <i class="bi bi-kanban"></i>
                                    <span class="fw-semibold text-truncate">@ws.Name</span>
                                </div>
                                <i class="bi bi-chevron-right" style="opacity:.65;"></i>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- CENTER: Notes -->
        <div class="col-12 col-lg-6">
            <div class="panel">
                <div class="panel-h d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2">
                    <div>
                        <div class="fw-bold" style="letter-spacing:-.01em;">@((workspace == null) ? "Notas sin workspace" : "Notas")</div>
                        <div class="text-muted small">@notes.Count nota(s)</div>
                    </div>
                    <div class="text-muted small">Ordenadas por última actualización</div>
                </div>
                <div class="panel-b">
                    @if (!notes.Any())
                    {
                        <div class="text-center py-5">
                            <div class="display-6">📝</div>
                            <h4 class="fw-bold mt-3">Aún no hay notas aquí</h4>
                            <p class="text-muted mb-4">Crea tu primera nota y empieza a organizarte.</p>
                            <a class="btn btn-primary btn-lg" asp-controller="Pages" asp-action="Create" asp-route-workspaceId="@returnWsId">
                                <i class="bi bi-plus-circle me-2"></i>Crear nota
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">
                            @foreach (var p in recentNotes)
                            {
                                var snippet = string.IsNullOrWhiteSpace(p.Content)
                                    ? "Sin contenido"
                                    : (p.Content.Length > 140 ? p.Content.Substring(0, 140) + "…" : p.Content);

                                <div class="col-12">
                                    <div class="note-card p-4">
                                        <div class="d-flex flex-column flex-md-row align-items-md-start justify-content-between gap-3">
                                            <div class="min-w-0">
                                                <h3 class="note-title text-truncate">@p.Title</h3>
                                                <div class="text-muted small mt-1">
                                                    Actualizado: @p.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                                </div>
                                                <p class="note-snippet">@snippet</p>
                                            </div>
                                            <div class="d-flex flex-wrap gap-2 justify-content-md-end">
                                                <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@p.Id">
                                                    <i class="bi bi-pencil me-2"></i>Editar
                                                </a>
                                                <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@p.Id">
                                                    <i class="bi bi-trash me-2"></i>Eliminar
                                                </a>
                                            </div>
                                        </div>

                                        <div class="mt-3">
                                            <form class="d-flex flex-column flex-md-row gap-2 align-items-md-center" asp-action="Move" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="pageId" value="@p.Id" />
                                                <input type="hidden" name="returnWorkspaceId" value="@returnWsId" />

                                                <label class="text-muted small" style="min-width:110px;">Mover a:</label>
                                                <select class="form-select mini-select" name="workspaceId">
                                                    <option value="">Sin workspace</option>
                                                    @foreach (var ws in workspaces)
                                                    {
                                                        <option value="@ws.Id" selected="@(p.WorkspaceId == ws.Id)">@ws.Name</option>
                                                    }
                                                </select>
                                                <button class="btn btn-sm btn-outline-secondary" type="submit">
                                                    <i class="bi bi-arrow-right-circle me-1"></i>Mover
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        @if (notes.Count > recentNotes.Count)
                        {
                            <div class="text-center mt-4">
                                <span class="text-muted">Mostrando @recentNotes.Count de @notes.Count notas.</span>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- RIGHT: Recent Files -->
        <div class="col-12 col-lg-3 right-col">
            <div class="panel">
                <div class="panel-h d-flex align-items-center justify-content-between">
                    <div class="fw-bold" style="letter-spacing:-.01em;">Archivos recientes</div>
                    <a class="btn btn-sm btn-outline-secondary" asp-controller="Files" asp-action="Index">Ver todos</a>
                </div>
                <div class="panel-b">
                    @if (!recentFiles.Any())
                    {
                        <div class="text-muted">Aún no has subido archivos.</div>
                    }
                    else
                    {
                        <div class="d-grid gap-2">
                            @foreach (var f in recentFiles)
                            {
                                <a class="d-flex align-items-center justify-content-between gap-2 text-decoration-none" href="@f.FilePath" target="_blank" style="color: var(--text); padding: 10px 12px; border-radius: 12px; border: 1px solid var(--border); background: rgba(255,255,255,.03);">
                                    <div class="d-flex align-items-center gap-2 min-w-0">
                                        <i class="bi bi-file-earmark"></i>
                                        <span class="text-truncate">@f.FileName</span>
                                    </div>
                                    <span class="text-muted small">@((f.FileSize / 1024)) KB</span>
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
