@using Microsoft.AspNetCore.Identity
@inject SignInManager<TwiceTasks.Models.ApplicationUser> SignInManager
@inject UserManager<TwiceTasks.Models.ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TwiceTasks</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TwiceTasks.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <!-- Inicializa el tema (evita flash) -->
    <script>
        (function() {
            try {
                var theme = localStorage.getItem('theme') || 'light';
                document.documentElement.classList.remove('light','dark');
                document.documentElement.classList.add(theme);
            } catch(e) { /* noop */ }
        })();
    </script>

    <style>
        :root {
            --headerH: 168px;
        }
        /* ==============================
                     Variables (light / dark se aplican sobre el elemento html)
                   =============================== */
        html.light {
            --bg: #f4f5f7;
            --text: #1c1c1e;
            --nav: #ffffff;
            --card: #ffffff;
            --border: rgba(0,0,0,0.12);
            --link: #0077ff;
            --toggler-invert: 0;
        }

        html.dark {
            --bg: #12141a;
            --text: #e6e6e6;
            --nav: #1a1c23;
            --card: #1d1f27;
            --border: rgba(255,255,255,0.18);
            --link: #4da8ff;
            --toggler-invert: 1;
        }

        /* ==============================
                   Base layout styles
                   =============================== */
        body {
            background: var(--bg);
            color: var(--text);
            font-family: "Segoe UI", Roboto, sans-serif;
            margin: 0;
            padding: 0;
        }

        /* ========== HEADER (no navbar) ========== */
        .masthead {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: var(--headerH);
            z-index: 55;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 22px 18px 18px;
            text-align: center;
            background: linear-gradient(
                180deg,
                color-mix(in srgb, var(--nav) 92%, transparent),
                color-mix(in srgb, var(--nav) 70%, transparent)
            );
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border);
        }

        .masthead-brand {
            text-decoration: none;
            color: var(--text);
            font-weight: 900;
            letter-spacing: -0.8px;
            font-size: clamp(2rem, 3.2vw, 2.8rem);
            line-height: 1.05;
        }

        .masthead-brand:hover { color: var(--text); opacity: .92; }

        .masthead-actions {
            margin-top: 14px;
            display: flex;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        /* Big theme toggle in a corner */
        .theme-toggle-fab {
            position: fixed;
            top: 16px;
            right: 16px;
            z-index: 70;
            width: 58px;
            height: 58px;
            border-radius: 18px;
            border: 1px solid var(--border);
            background: color-mix(in srgb, var(--card) 86%, transparent);
            color: var(--text);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            box-shadow: 0 14px 28px rgba(0,0,0,.16);
            transition: transform .12s ease, background .12s ease, border-color .12s ease;
        }

        .theme-toggle-fab:hover {
            background: color-mix(in srgb, var(--border) 35%, transparent);
            transform: translateY(-1px);
        }

        .tt-btn {
            height: 46px;
            padding: 0 16px;
            border-radius: 12px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text);
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            font-weight: 600;
            transition: transform .12s ease, background .12s ease, border-color .12s ease;
            white-space: nowrap;
        }

        .tt-btn:hover {
            background: color-mix(in srgb, var(--border) 35%, transparent);
            transform: translateY(-1px);
            color: var(--text);
        }

        .tt-btn-primary {
            background: var(--link);
            border-color: color-mix(in srgb, var(--link) 80%, #000);
            color: #fff;
        }

        .tt-btn-primary:hover {
            background: color-mix(in srgb, var(--link) 88%, #000);
            border-color: color-mix(in srgb, var(--link) 70%, #000);
            color: #fff;
        }

        /* ========== SIDEBAR (collapsed icons -> expand to show text) ========== */
        .sidebar {
            background-color: var(--card);
            color: var(--text);
            border-right: 1px solid var(--border);
            width: 65px; /* collapsed width */
            height: calc(100vh - var(--headerH));
            position: fixed;
            top: var(--headerH);
            left: 0;
            padding: 18px 8px;
            overflow: hidden;
            transition: width 0.22s ease;
            z-index: 50;
        }

            .sidebar:hover {
                width: 240px;
            }

            .sidebar h2 {
                font-size: 1.05rem;
                margin: 6px 0 14px 6px;
                opacity: 0;
                white-space: nowrap;
                transition: opacity .18s;
            }

            .sidebar:hover h2 {
                opacity: 1;
            }

            .sidebar a {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 10px;
                color: var(--text) !important;
                text-decoration: none;
                border-radius: 8px;
                transition: background .15s, color .15s;
                white-space: nowrap;
            }

                .sidebar a i {
                    font-size: 1.12rem;
                    width: 24px;
                    text-align: center;
                }
                /* texto (span) oculto cuando collapsed */
                .sidebar a span {
                    opacity: 0;
                    transition: opacity .18s;
                    transform: translateX(-6px);
                    display: inline-block;
                }

            .sidebar:hover a span {
                opacity: 1;
                transform: translateX(0);
            }

            .sidebar a:hover {
                background: var(--border);
            }

        /* When sidebar hidden (not rendered) ensure main content margin */
        .main-wrapper {
            margin-left: 80px;
            margin-top: calc(var(--headerH) + 18px);
            padding: 24px;
            transition: margin-left .22s;
        }
        /* when sidebar present and expanded push content */
        .sidebar:hover ~ .main-wrapper {
            margin-left: 260px;
        }

        /* If no sidebar in DOM (user not logged) reduce left margin */
        html.no-sidebar .main-wrapper {
            margin-left: 24px;
        }

        /* ========== Footer ========== */
        footer {
            text-align: center;
            padding: 18px;
            color: var(--text);
        }

        /* small helpers */
        .btn-create {
            margin-top: 8px;
        }
    </style>
</head>
<body>
    <!-- Big theme toggle in corner -->
    <button id="darkModeToggle" class="theme-toggle-fab" aria-label="Activar o desactivar modo oscuro" title="Tema">🌙</button>

    <!-- HEADER (no navbar): big app name + auth buttons below -->
    <header class="masthead" role="banner">
        <a class="masthead-brand" asp-controller="Home" asp-action="Index" aria-label="Ir al inicio">TwiceTasks</a>
        <div class="masthead-actions">
            <partial name="_LoginPartial" />
        </div>
    </header>

    @* Sidebar only for authenticated users *@
    @if (User?.Identity?.IsAuthenticated ?? false)
    {
        <div class="sidebar" role="navigation" aria-label="Dashboard">
            <h2>Mi Dashboard</h2>
            <a asp-controller="Home" asp-action="Index" title="Inicio">
                <i class="bi bi-house-door"></i><span>Inicio</span>
            </a>
            <a asp-controller="Workspaces" asp-action="Index" title="Workspaces">
                <i class="bi bi-kanban"></i><span>Workspaces</span>
            </a>
            <a asp-controller="Pages" asp-action="Index" title="Notas">
                <i class="bi bi-journal-text"></i><span>Notas</span>
            </a>
            <a asp-controller="Files" asp-action="Index" title="Archivos">
                <i class="bi bi-folder"></i><span>Archivos</span>
            </a>
        </div>
    }
    else
    {
        @* Add helper class so main has smaller left margin when sidebar not rendered *@
        <script>document.documentElement.classList.add('no-sidebar');</script>
    }

    <!-- MAIN WRAPPER -->
    <div class="main-wrapper">
        @* Optional carousel section for homepage only. Views can define section "HomeCarousel" *@
        @RenderSection("HomeCarousel", required: false)

        @RenderBody()
    </div>

    <footer>
        © 2025 — TwiceTasks
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- THEME TOGGLE (uses <html> classes 'light' / 'dark' to control CSS variables) -->
    <script>
        (function(){
            const html = document.documentElement;
            const btn = document.getElementById('darkModeToggle');

            // Ensure there is a theme stored
            if (!localStorage.getItem('theme')) localStorage.setItem('theme','light');

            // Apply current theme (script in head already set, but keep this to sync button text)
            const current = localStorage.getItem('theme') || 'light';
            html.classList.remove('light','dark');
            html.classList.add(current);
            if (btn) btn.textContent = html.classList.contains('dark') ? '☀️' : '🌙';

            if (btn) {
                btn.addEventListener('click', function(){
                    const now = html.classList.contains('dark') ? 'light' : 'dark';
                    html.classList.remove('light','dark');
                    html.classList.add(now);
                    localStorage.setItem('theme', now);
                    btn.textContent = now === 'dark' ? '☀️' : '🌙';
                });
            }
        })();
    </script>

    @* RenderScripts section placed at the very end to avoid "section not rendered" error. Views may define the Scripts section. *@
    @RenderSection("Scripts", required: false)
</body>
</html>
