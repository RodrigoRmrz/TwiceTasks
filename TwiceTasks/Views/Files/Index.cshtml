@model TwiceTasks.ViewModels.FilesIndexViewModel
@{
    ViewData["Title"] = "Archivos";
    var selected = Model.Collections.FirstOrDefault(c => c.Id == Model.SelectedCollectionId);
    var selectedName = Model.SelectedCollectionId == 0 ? "General" : (selected?.Name ?? "Colección");
}

<style>
    .files-shell { max-width: 1700px; }
    .pane {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 18px;
        box-shadow: 0 10px 26px var(--shadow);
    }
    .pane-h {
        padding: 14px 16px;
        border-bottom: 1px solid var(--border);
    }
    .pane-b { padding: 16px; }

    .collection-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 10px 12px;
        border-radius: 12px;
        text-decoration: none;
        color: var(--text);
        border: 1px solid transparent;
    }
    .collection-link:hover {
        background: rgba(255,255,255,.04);
        border-color: var(--border);
        color: var(--text);
    }
    .collection-link.active {
        background: rgba(13,110,253,.14);
        border-color: rgba(13,110,253,.35);
    }

    .upload-tile {
        border: 2px dashed rgba(13,110,253,.45);
        background: rgba(13,110,253,.06);
        border-radius: 18px;
        padding: 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
    }

    .file-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 18px;
        box-shadow: 0 10px 26px var(--shadow);
        padding: 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        transition: transform .16s ease;
    }
    .file-card:hover { transform: translateY(-2px); }

    .file-icon {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        border: 1px solid var(--border);
        background: rgba(255,255,255,.04);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 auto;
    }

    .file-name { font-weight: 700; letter-spacing: -.01em; }
    .file-meta { color: var(--text-muted); opacity: .9; font-size: .9rem; }

    @@media (max-width: 992px) {
        .upload-tile { flex-direction: column; align-items: stretch; }
    }
</style>

<div class="container-xxl files-shell py-4">
    <div class="d-flex flex-column flex-md-row align-items-md-end justify-content-between gap-3 mb-4">
        <div>
            <h1 class="fw-bold m-0" style="letter-spacing:-.02em;">Archivos</h1>
            <p class="text-muted mb-0">Sube, organiza y comparte documentos. Colección actual: <strong>@selectedName</strong></p>
        </div>
        <div>
            <a class="btn btn-outline-secondary btn-lg" asp-controller="Collection" asp-action="Create">
                <i class="bi bi-folder-plus me-2"></i>Nueva colección
            </a>
        </div>
    </div>

    <div class="row g-3">
        <!-- Collections -->
        <div class="col-12 col-lg-3">
            <div class="pane">
                <div class="pane-h fw-bold" style="letter-spacing:-.01em;">Colecciones</div>
                <div class="pane-b">
                    <div class="d-grid gap-1">
                        <a class="collection-link @(Model.SelectedCollectionId == 0 ? "active" : "")" asp-controller="Files" asp-action="Index" asp-route-collectionId="0">
                            <span class="d-flex align-items-center gap-2"><i class="bi bi-grid"></i>General</span>
                            <span class="badge rounded-pill text-bg-secondary">@Model.Files.Count</span>
                        </a>

                        @foreach (var col in Model.Collections)
                        {
                            <a class="collection-link @(Model.SelectedCollectionId == col.Id ? "active" : "")" asp-controller="Files" asp-action="Index" asp-route-collectionId="@col.Id">
                                <span class="d-flex align-items-center gap-2"><i class="bi bi-folder"></i>@col.Name</span>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Files -->
        <div class="col-12 col-lg-9">
            <div class="pane mb-3">
                <div class="pane-b">
                    <form method="post" enctype="multipart/form-data" asp-action="Upload">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="collectionId" value="@Model.SelectedCollectionId" />
                        <div class="upload-tile">
                            <div class="d-flex align-items-center gap-3">
                                <div class="file-icon"><i class="bi bi-cloud-arrow-up"></i></div>
                                <div>
                                    <div class="fw-bold" style="letter-spacing:-.01em;">Sube un archivo</div>
                                    <div class="text-muted">Se guardará en <strong>@selectedName</strong></div>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <input class="form-control" type="file" name="file" onchange="this.form.submit()" style="max-width: 380px;" />
                                <button class="btn btn-primary btn-lg" type="submit">
                                    <i class="bi bi-upload me-2"></i>Subir
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            @if (!Model.Files.Any())
            {
                <div class="pane">
                    <div class="pane-b text-muted">No hay archivos en esta colección.</div>
                </div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var f in Model.Files.OrderByDescending(x => x.UploadedAt))
                    {
                        <div class="col-12 col-md-6 col-xl-4">
                            <div class="file-card h-100">
                                <div class="d-flex align-items-center gap-3 min-w-0">
                                    <div class="file-icon"><i class="bi bi-file-earmark"></i></div>
                                    <div class="min-w-0">
                                        <div class="file-name text-truncate">@f.FileName</div>
                                        <div class="file-meta">@((f.FileSize / 1024)) KB · @f.UploadedAt.ToLocalTime().ToShortDateString()</div>
                                    </div>
                                </div>

                                <div class="d-flex align-items-center gap-2">
                                    <a class="btn btn-outline-secondary btn-sm" href="@f.FilePath" target="_blank" title="Ver">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <form method="post" asp-action="Delete" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@f.Id" />
                                        <input type="hidden" name="collectionId" value="@Model.SelectedCollectionId" />
                                        <button class="btn btn-outline-danger btn-sm" type="submit" title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
