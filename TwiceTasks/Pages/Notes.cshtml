@page
@model TwiceTasks.Pages.NotesModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Notas";
}

<style>
/* En Razor, @ en CSS debe escaparse con @@ */
@@media (min-width: 992px) {
    .notes-shell { min-height: calc(100vh - 180px); }
}

.notes-shell {
    display: grid;
    grid-template-columns: 320px 1fr 360px;
    gap: 1.25rem;
}

@@media (max-width: 1199.98px) {
    .notes-shell { grid-template-columns: 280px 1fr; }
    .notes-right { display:none; }
}

@@media (max-width: 767.98px) {
    .notes-shell { grid-template-columns: 1fr; }
    .notes-left { order: 2; }
}

.ws-item:hover { transform: translateY(-1px); }
</style>

<div class="container-xxl py-4">
    <div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-4">
        <div>
            <h1 class="display-6 fw-bold mb-1">Notas</h1>
            <div class="text-muted">Workspaces, notas y archivos en un solo lugar.</div>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary btn-lg" asp-controller="Workspaces" asp-action="Index">
                Workspaces
            </a>
            <a class="btn btn-primary btn-lg" asp-controller="Pages" asp-action="Create" asp-route-workspaceId="@Model.WorkspaceId">
                + Nueva nota
            </a>
        </div>
    </div>

    <div class="notes-shell notes-shell">
        <!-- LEFT: Workspaces -->
        <div class="notes-left">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="fw-semibold">Workspaces</div>
                        <a class="btn btn-sm btn-outline-primary" asp-controller="Workspaces" asp-action="Create">Nuevo</a>
                    </div>

                    <a class="list-group-item list-group-item-action rounded-3 mb-2 ws-item @(Model.WorkspaceId == null ? "active" : "")" href="/Notes">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-semibold">Sin workspace</span>
                            <span class="badge bg-secondary">@Model.UnassignedPages.Count</span>
                        </div>
                        <small class="opacity-75">Notas sueltas</small>
                    </a>

                    <div class="d-grid gap-2">
                        @foreach (var ws in Model.Workspaces)
                        {
                            var isActive = Model.WorkspaceId == ws.Id;
                            <a class="list-group-item list-group-item-action rounded-3 ws-item @(isActive ? "active" : "")" href="/Notes?workspaceId=@ws.Id">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fw-semibold">@ws.Name</span>
                                    <span class="badge bg-secondary">@ws.Pages.Count</span>
                                </div>
                                <small class="opacity-75">Abrir notas</small>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- CENTER: Notes list -->
        <div>
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                        <div>
                            <div class="fw-semibold">@(Model.WorkspaceId == null ? "Notas sin workspace" : $"Notas en {Model.SelectedWorkspace?.Name}")</div>
                            <div class="text-muted small">Haz clic en una nota para editarla.</div>
                        </div>
                        <div class="text-muted small">
                            @(Model.WorkspaceId == null ? Model.UnassignedPages.Count : Model.Pages.Count) notas
                        </div>
                    </div>

                    <div class="row g-3">
                        @{
                            var list = Model.WorkspaceId == null ? Model.UnassignedPages : Model.Pages;
                        }

                        @if (!list.Any())
                        {
                            <div class="col-12">
                                <div class="p-5 text-center border rounded-4">
                                    <div class="mb-2">📄</div>
                                    <div class="fw-semibold">No hay notas todavía</div>
                                    <div class="text-muted">Crea tu primera nota para empezar.</div>
                                    <a class="btn btn-primary btn-lg mt-3" asp-controller="Pages" asp-action="Create" asp-route-workspaceId="@Model.WorkspaceId">Crear nota</a>
                                </div>
                            </div>
                        }
                        else
                        {
                            foreach (var p in list)
                            {
                                <div class="col-12 col-md-6 col-xl-4">
                                    <div class="card h-100 shadow-sm border-0 rounded-4">
                                        <div class="card-body p-4 d-flex flex-column">
                                            <div class="d-flex justify-content-between align-items-start gap-2">
                                                <div class="min-w-0">
                                                    <div class="fw-bold text-truncate" title="@p.Title">@p.Title</div>
                                                    <div class="text-muted small">Actualizado: @p.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                                                </div>
                                                <span class="badge text-bg-secondary">@(p.Workspace?.Name ?? "Sin workspace")</span>
                                            </div>

                                            <div class="text-muted mt-3" style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">
                                                @(!string.IsNullOrWhiteSpace(p.Content) ? p.Content : "(Sin contenido)")
                                            </div>

                                            <div class="mt-auto pt-3 d-flex gap-2 flex-wrap">
                                                <a class="btn btn-primary" asp-controller="Pages" asp-action="Edit" asp-route-id="@p.Id">Editar</a>
                                                <a class="btn btn-outline-secondary" asp-controller="Pages" asp-action="Details" asp-route-id="@p.Id">Ver</a>
                                                <a class="btn btn-outline-danger" asp-controller="Pages" asp-action="Delete" asp-route-id="@p.Id">Eliminar</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT: Recent files -->
        <div class="notes-right">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="fw-semibold">Archivos recientes</div>
                        <a class="btn btn-sm btn-outline-secondary" asp-controller="Files" asp-action="Index">Ver todos</a>
                    </div>

                    @if (!Model.RecentFiles.Any())
                    {
                        <div class="text-muted">Aún no has subido archivos.</div>
                        <a class="btn btn-outline-primary mt-3" asp-controller="Files" asp-action="Index">Subir archivo</a>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var f in Model.RecentFiles)
                            {
                                <a class="list-group-item list-group-item-action d-flex align-items-center justify-content-between" href="@f.Url" target="_blank" rel="noopener">
                                    <div class="min-w-0">
                                        <div class="fw-semibold text-truncate">@f.FileName</div>
                                        <small class="text-muted">@f.UploadedAt.ToString("dd/MM/yyyy")</small>
                                    </div>
                                    <span class="badge text-bg-light">Abrir</span>
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
