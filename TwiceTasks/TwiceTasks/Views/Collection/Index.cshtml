@model IEnumerable<TwiceTasks.Models.Collection>

<div class="collections-header">
    <h1>🗂️ Mis Colecciones</h1>
    <p class="subtitle">Organiza tus archivos en carpetas personalizadas.</p>

    <a asp-controller="Collection" asp-action="Create" class="new-btn">
        <i class="bi bi-folder-plus"></i> Nueva colección
    </a>
</div>

<div class="collections-grid">
    @foreach (var col in Model)
    {
        <div class="collection-card">
            <a href="/Files?collectionId=@col.Id" class="card-link">
                <div class="icon">
                    <i class="bi bi-folder-fill"></i>
                </div>
                <h3>@col.Name</h3>
                <p class="count">@((col.Files?.Count ?? 0)) archivos</p>
            </a>

            <!-- Botones -->
            <div class="collection-actions">
                <a asp-action="Edit" asp-route-id="@col.Id" class="edit-btn">
                    <i class="bi bi-pencil-square"></i>
                </a>

                <a asp-action="Delete" asp-route-id="@col.Id" class="delete-btn">
                    <i class="bi bi-trash"></i>
                </a>
            </div>
        </div>
    }
</div>

<style>

    .collections-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 26px;
    }

    .new-btn {
        background: var(--accent);
        color: white;
        padding: 10px 16px;
        font-weight: 600;
        border-radius: var(--radius);
        display: flex;
        align-items: center;
        gap: 6px;
        transition: .25s;
        box-shadow: 0 4px 12px var(--shadow);
    }

        .new-btn:hover {
            opacity: .85;
        }

    .collections-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 22px;
    }

    .collection-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        padding: 18px;
        border-radius: var(--radius);
        box-shadow: 0 4px 14px var(--shadow);
        transition: .25s;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        position: relative;
    }

        .collection-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px var(--shadow);
        }

    .card-link {
        text-decoration: none;
        color: inherit;
    }

    .collection-card .icon i {
        font-size: 2.4rem;
        color: var(--accent);
    }

    .collection-card h3 {
        margin-top: 10px;
        color: var(--text);
        font-weight: 700;
    }

    .collection-card .count {
        color: var(--text-muted);
        margin-top: 6px;
        font-size: .9rem;
    }

    /* Botones dentro del card */
    .collection-actions {
        margin-top: 14px;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .edit-btn, .delete-btn {
        padding: 6px 10px;
        border-radius: 6px;
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: .2s;
    }

    .edit-btn {
        background: var(--bg-soft);
        border: 1px solid var(--border);
        color: var(--text);
    }

        .edit-btn:hover {
            background: var(--bg);
            opacity: .85;
        }

    .delete-btn {
        background: rgba(255, 0, 0, 0.1);
        border: 1px solid rgba(255, 0, 0, 0.2);
        color: #e55353;
    }

        .delete-btn:hover {
            background: rgba(255, 0, 0, 0.18);
        }

</style>
