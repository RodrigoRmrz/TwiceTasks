@model TwiceTasks.Models.Collection;

<div class="max-w-xl mx-auto mt-10">
    <h1 class="text-2xl font-bold mb-4">Nueva colección</h1>

    <form asp-action="Create" method="post" class="space-y-4">

        <div>
            <label class="block font-semibold">Nombre</label>
            <input asp-for="Name" class="w-full border rounded p-2" />
        </div>

        <div>
            <label class="block font-semibold">Descripción</label>
            <textarea asp-for="Description" class="w-full border rounded p-2"></textarea>
        </div>

        <button class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
            Crear
        </button>
    </form>
</div>
