@model IEnumerable<TwiceTasks.Models.FileResource>

<h2>Mis Archivos</h2>

<form method="post" enctype="multipart/form-data" asp-action="Upload">
    <input type="file" name="file" />
    <button class="btn btn-primary">Subir</button>
</form>

<hr />

<div class="row">
    @foreach (var file in Model)
    {
        <div class="col-md-3 mb-3">
            <div class="card p-2">
                <strong>@file.FileName</strong>
                <small>@(file.FileSize / 1024) KB</small>
                <a href="@file.FilePath" target="_blank">Ver</a> |
                <a asp-action="Delete" asp-route-id="@file.Id" class="text-danger">Eliminar</a>
            </div>
        </div>
    }
</div>