@model TwiceTasks.ViewModels.FilesIndexViewModel

<div class="files-header">
    <h1>📁 Mis Archivos</h1>
    <p class="subtitle">Organiza tus documentos en colecciones personalizadas.</p>

    <a asp-controller="Collection" asp-action="Create" class="new-collection-btn">
        <i class="bi bi-folder-plus"></i>
        Nueva colección
    </a>
</div>

<!-- COLLECTIONS STRIP -->
<div class="collections-strip">

    <!-- BOTÓN TODAS -->
    <a href="/Files"
       class="collection-chip @(Model.SelectedCollectionId == 0 ? "active" : "")">
        <i class="bi bi-folder"></i> Todas
    </a>

    <!-- COLECCIONES DEL USUARIO -->
    @foreach (var col in Model.Collections)
    {
        <a href="/Files?collectionId=@col.Id"
           class="collection-chip @(Model.SelectedCollectionId == col.Id ? "active" : "")">
            <i class="bi bi-folder-fill"></i> @col.Name
        </a>
    }
</div>

<!-- UPLOAD -->
<div class="upload-box">
    <form method="post" enctype="multipart/form-data" asp-action="Upload" class="upload-form">
        <input type="hidden" name="collectionId" value="@Model.SelectedCollectionId" />
        <label class="upload-area">
            <i class="bi bi-cloud-arrow-up"></i>
            <span>Subir archivo</span>
            <input type="file" name="file" hidden onchange="this.form.submit()" />
        </label>
    </form>
</div>

<!-- FILES GRID -->
<div class="files-grid">
    @if (!Model.Files.Any())
    {
        <p class="empty-text">No hay archivos en esta colección.</p>
    }
    else
    {
        foreach (var file in Model.Files)
        {
            <div class="file-card">
                <div class="file-icon">
                    <i class="bi bi-file-earmark-text"></i>
                </div>
                <div class="file-info">
                    <span class="file-name">@file.FileName</span>
                    <span class="file-size">@((file.FileSize / 1024)) KB</span>
                </div>
                <div class="file-actions">
                    <a href="@file.FilePath" target="_blank" class="view-btn">
                        <i class="bi bi-eye"></i>
                    </a>
                    <a asp-action="Delete" asp-route-id="@file.Id" class="delete-btn">
                        <i class="bi bi-trash"></i>
                    </a>
                </div>
            </div>
        }
    }
</div>

<style>

    /* HEADER */
    .files-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }

    .new-collection-btn {
        background: var(--accent);
        color: white;
        padding: 10px 18px;
        border-radius: var(--radius);
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: .2s;
    }

        .new-collection-btn:hover {
            opacity: .85;
        }

    /* COLLECTION STRIP */
    .collections-strip {
        display: flex;
        gap: 12px;
        overflow-x: auto;
        padding-bottom: 10px;
        margin-bottom: 25px;
    }

    .collection-chip {
        padding: 8px 14px;
        border-radius: var(--radius);
        background: var(--bg-soft);
        border: 1px solid var(--border);
        text-decoration: none;
        font-weight: 500;
        color: var(--text);
        display: flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
        transition: .2s;
    }

        .collection-chip:hover {
            background: var(--bg);
        }

        .collection-chip.active {
            background: var(--accent-soft);
            border-color: var(--accent);
            color: var(--accent-dark);
        }

    /* UPLOAD */
    .upload-box {
        display: flex;
        justify-content: center;
        margin-bottom: 30px;
    }

    .upload-area {
        padding: 20px 28px;
        background: var(--bg);
        border: 2px dashed var(--border);
        border-radius: var(--radius);
        cursor: pointer;
        text-align: center;
        width: 100%;
        max-width: 380px;
        transition: .2s;
    }

        .upload-area:hover {
            background: var(--bg-soft);
        }

    /* FILE GRID */
    .files-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 20px;
    }

    .file-card {
        background: var(--card-bg);
        padding: 18px;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        box-shadow: 0 4px 12px var(--shadow);
        transition: .2s;
    }

        .file-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 20px var(--shadow);
        }

    .file-icon i {
        font-size: 2.6rem;
        color: var(--accent);
    }

    .file-name {
        font-weight: 600;
    }

    .file-size {
        color: var(--text-muted);
        font-size: .9rem;
    }

    .file-actions {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        margin-top: 12px;
    }

    .delete-btn {
        color: #d9534f;
    }

    /* EMPTY TEXT */
    .empty-text {
        text-align: center;
        color: var(--text-muted);
        grid-column: 1 / -1;
    }

</style>
