@model TwiceTasks.Models.Page

@{
    ViewData["Title"] = Model.Title;
}

<div class="page-editor-container">

    <!-- FORM EDIT PAGE -->
    <form asp-action="Edit" method="post">

        <input type="hidden" name="Id" value="@Model.Id" />

        <input type="text" name="Title" value="@Model.Title" class="page-title-input" placeholder="Sin título..." />

        <div id="editorjs"></div>

        <input type="hidden" name="Content" id="Content" value='@(Model.Content ?? "{}")' />

        <button type="submit" class="btn btn-primary mt-4">
            Guardar
        </button>
    </form>

    <!-- ATTACHMENTS -->
    <div class="attachments-panel mt-5">
        @* <h6 class="attachments-title">📎 Archivos adjuntos</h6> *@

        <form asp-controller="Files" asp-action="UploadToPage" method="post" enctype="multipart/form-data"
            class="attachment-upload-row">

            <input type="hidden" name="pageId" value="@Model.Id" />

            <!-- INPUT REAL (oculto) -->
            <input type="file" name="file" id="fileInput" hidden />

            <!-- LABEL BONITO -->
            <label for="fileInput" class="file-picker">
                📎 <span id="fileName">Ningún archivo seleccionado</span>
            </label>

            <button class="btn btn-sm btn-primary">
                Subir
            </button>
        </form>


        <div class="attachments-list mt-3">
            @foreach (var file in (IEnumerable<TwiceTasks.Models.FileResource>)ViewBag.Files)
            {
                <div class="attachment-item">
                    <a href="@file.FilePath" target="_blank">
                        📄 @file.FileName
                    </a>
                    <a asp-controller="Files" asp-action="Delete" asp-route-id="@file.Id" class="delete-attachment">
                        🗑
                    </a>
                </div>
            }
        </div>
    </div>

</div>

@section Scripts {
    <script>
        const editor = new EditorJS({
            holder: 'editorjs',
            data: @Html.Raw(Model.Content ?? "{}"),
            onChange: async () => {
                const content = await editor.save();
                document.getElementById("Content").value = JSON.stringify(content);
            }
        });
    </script>
    <script>
        const fileInput = document.getElementById("fileInput");
        const fileNameSpan = document.getElementById("fileName");

        if (fileInput) {
            fileInput.addEventListener("change", () => {
                fileNameSpan.textContent =
                    fileInput.files.length > 0
                        ? fileInput.files[0].name
                        : "Ningún archivo seleccionado";
            });
        }
    </script>

}