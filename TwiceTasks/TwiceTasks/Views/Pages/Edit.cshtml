@model TwiceTasks.Models.Page

@{
    ViewData["Title"] = Model.Title;
}

<form asp-action="Edit" method="post">
    <div class="container mt-4">

        <input asp-for="Id" type="hidden" />

        <input asp-for="Title"
               class="form-control form-control-lg mb-3 border-0 fw-bold"
               style="font-size: 2rem" />

        <div id="editorjs"></div>

        <input type="hidden" name="Content" id="Content" value='@(Model.Content ?? "{}")' />

        <button type="submit" class="btn btn-primary mt-3">Guardar</button>

    </div>
</form>

@section Scripts {
    <script>
        const editor = new EditorJS({
            holder: 'editorjs',
            data: @Html.Raw(Model.Content ?? "{}"),
            onChange: async () => {
                const content = await editor.save();
                document.getElementById("Content").value = JSON.stringify(content);
            }
        });
    </script>
}
