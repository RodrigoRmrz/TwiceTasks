@using Microsoft.AspNetCore.Identity
@inject SignInManager<TwiceTasks.Models.ApplicationUser> SignInManager
@inject UserManager<TwiceTasks.Models.ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TwiceTasks</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TwiceTasks.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <!-- Inicializa el tema (evita flash) -->
    <script>
        (function() {
            try {
                var theme = localStorage.getItem('theme') || 'light';
                document.documentElement.classList.remove('light','dark');
                document.documentElement.classList.add(theme);
            } catch(e) { /* noop */ }
        })();
    </script>

    <style>
        /* ==============================
                     Variables (light / dark se aplican sobre el elemento html)
                   =============================== */
        html.light {
            --bg: #f4f5f7;
            --text: #1c1c1e;
            --nav: #ffffff;
            --card: #ffffff;
            --border: rgba(0,0,0,0.12);
            --link: #0077ff;
            --toggler-invert: 0;
        }

        html.dark {
            --bg: #12141a;
            --text: #e6e6e6;
            --nav: #1a1c23;
            --card: #1d1f27;
            --border: rgba(255,255,255,0.18);
            --link: #4da8ff;
            --toggler-invert: 1;
        }

        /* ==============================
                   Base layout styles
                   =============================== */
        body {
            background: var(--bg);
            color: var(--text);
            font-family: "Segoe UI", Roboto, sans-serif;
            margin: 0;
            padding: 0;
        }

        /* ========== TOPBAR (mini) ========== */
        .topbar {
            height: 60px;
            background: var(--nav);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 60;
        }

        .topbar-title {
            font-size: 1.3rem;
            font-weight: 600;
            color: var(--text);
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        /* hamburger icon invert for dark */
        .navbar-toggler-icon {
            filter: invert(var(--toggler-invert));
        }

        /* ========== SIDEBAR (collapsed icons -> expand to show text) ========== */
        .sidebar {
            background-color: var(--card);
            color: var(--text);
            border-right: 1px solid var(--border);
            width: 65px; /* collapsed width */
            height: calc(100vh - 60px);
            position: fixed;
            top: 60px;
            left: 0;
            padding: 18px 8px;
            overflow: hidden;
            transition: width 0.22s ease;
            z-index: 50;
        }

            .sidebar:hover {
                width: 240px;
            }

            .sidebar h2 {
                font-size: 1.05rem;
                margin: 6px 0 14px 6px;
                opacity: 0;
                white-space: nowrap;
                transition: opacity .18s;
            }

            .sidebar:hover h2 {
                opacity: 1;
            }

            .sidebar a {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 10px;
                color: var(--text) !important;
                text-decoration: none;
                border-radius: 8px;
                transition: background .15s, color .15s;
                white-space: nowrap;
            }

                .sidebar a i {
                    font-size: 1.12rem;
                    width: 24px;
                    text-align: center;
                }
                /* texto (span) oculto cuando collapsed */
                .sidebar a span {
                    opacity: 0;
                    transition: opacity .18s;
                    transform: translateX(-6px);
                    display: inline-block;
                }

            .sidebar:hover a span {
                opacity: 1;
                transform: translateX(0);
            }

            .sidebar a:hover {
                background: var(--border);
            }

        /* When sidebar hidden (not rendered) ensure main content margin */
        .main-wrapper {
            margin-left: 80px;
            margin-top: 80px;
            padding: 24px;
            transition: margin-left .22s;
        }
        /* when sidebar present and expanded push content */
        .sidebar:hover ~ .main-wrapper {
            margin-left: 260px;
        }

        /* If no sidebar in DOM (user not logged) reduce left margin */
        body.no-sidebar .main-wrapper {
            margin-left: 24px;
        }

        /* ========== Footer ========== */
        footer {
            text-align: center;
            padding: 18px;
            color: var(--text);
        }

        /* small helpers */
        .btn-create {
            margin-top: 8px;
        }
    </style>
</head>
<body>
    <!-- TOPBAR -->
    <div class="topbar" role="banner">
        <div class="topbar-title">TwiceTasks</div>
        <div class="topbar-right">
            <button id="darkModeToggle" class="btn btn-sm btn-outline-secondary" aria-label="Toggle theme">🌙</button>
            <!-- LoginPartial (si usa Identity) -->
            <partial name="_LoginPartial" />
        </div>
    </div>

    @* Sidebar only for authenticated users *@
    @if (User?.Identity?.IsAuthenticated ?? false)
    {
        <div class="sidebar" role="navigation" aria-label="Dashboard">
            <h2>Mi Dashboard</h2>
            <a asp-controller="Home" asp-action="Index" title="Inicio">
                <i class="bi bi-house-door"></i><span>Inicio</span>
            </a>
            <a asp-controller="Workspaces" asp-action="Index" title="Workspaces">
                <i class="bi bi-kanban"></i><span>Workspaces</span>
            </a>
            <a asp-controller="Notes" asp-action="Index" title="Notas">
                <i class="bi bi-journal-text"></i><span>Notas</span>
            </a>
            <a asp-controller="Files" asp-action="Index" title="Archivos">
                <i class="bi bi-folder"></i><span>Archivos</span>
            </a>
        </div>
    }
    else
    {
        @* Add helper class so main has smaller left margin when sidebar not rendered *@
        <script>document.documentElement.classList.add('no-sidebar');</script>
    }

    <!-- MAIN WRAPPER -->
    <div class="main-wrapper">
        @* Optional carousel section for homepage only. Views can define section "HomeCarousel" *@
        @RenderSection("HomeCarousel", required: false)

        @RenderBody()
    </div>

    <footer>
        © 2025 — TwiceTasks
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- THEME TOGGLE (uses <html> classes 'light' / 'dark' to control CSS variables) -->
    <script>
        (function(){
            const html = document.documentElement;
            const btn = document.getElementById('darkModeToggle');

            // Ensure there is a theme stored
            if (!localStorage.getItem('theme')) localStorage.setItem('theme','light');

            // Apply current theme (script in head already set, but keep this to sync button text)
            const current = localStorage.getItem('theme') || 'light';
            html.classList.remove('light','dark');
            html.classList.add(current);
            if (btn) btn.textContent = html.classList.contains('dark') ? '☀️' : '🌙';

            if (btn) {
                btn.addEventListener('click', function(){
                    const now = html.classList.contains('dark') ? 'light' : 'dark';
                    html.classList.remove('light','dark');
                    html.classList.add(now);
                    localStorage.setItem('theme', now);
                    btn.textContent = now === 'dark' ? '☀️' : '🌙';
                });
            }
        })();
    </script>

    @* RenderScripts section placed at the very end to avoid "section not rendered" error. Views may define the Scripts section. *@
    @RenderSection("Scripts", required: false)
</body>
</html>
