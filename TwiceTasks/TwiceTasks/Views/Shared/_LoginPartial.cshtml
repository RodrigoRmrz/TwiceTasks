@using Microsoft.AspNetCore.Identity
@using TwiceTasks.Models

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<div class="d-flex align-items-center gap-2 flex-wrap justify-content-center">
@if (SignInManager.IsSignedIn(User))
{
    <a class="tt-btn" asp-area="Identity" asp-page="/Account/Manage/Index" title="Mi cuenta">
        <i class="bi bi-person-circle"></i>
        <span>Cuenta</span>
    </a>

    <form class="d-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
        <button type="submit" class="tt-btn tt-btn-primary" title="Cerrar sesión">
            <i class="bi bi-box-arrow-right"></i>
            <span>Logout</span>
        </button>
    </form>
}
else
{
    <a class="tt-btn" asp-area="Identity" asp-page="/Account/Login" title="Iniciar sesión">
        <i class="bi bi-box-arrow-in-right"></i>
        <span>Login</span>
    </a>

    <a class="tt-btn tt-btn-primary" asp-area="Identity" asp-page="/Account/Register" title="Crear cuenta">
        <i class="bi bi-person-plus"></i>
        <span>Register</span>
    </a>
}
</div>
