@{
    ViewData["Title"] = "Calendario";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" />

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="mb-0">📅 Calendario <span class="badge bg-secondary ms-2">FullCalendar</span></h1>
    <button id="btnNewEvent" class="btn btn-primary">Nuevo evento</button>
</div>

<!-- Antiforgery para llamadas AJAX -->
<div style="display:none">@Html.AntiForgeryToken()</div>

<div class="card">
    <div class="card-body">
        <div id="twiceCalendar"></div>
    </div>
</div>

<!-- Modal Crear/Editar -->
<div class="modal fade" id="eventModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Evento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="evId" />

                <div class="mb-3">
                    <label class="form-label">Título</label>
                    <input class="form-control" id="evTitle" placeholder="Ej: Reunión" />
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="evAllDay" checked />
                    <label class="form-check-label" for="evAllDay">Todo el día</label>
                </div>

                <!-- All-day -->
                <div id="allDayFields">
                    <div class="mb-3">
                        <label class="form-label">Inicio</label>
                        <input type="date" class="form-control" id="evStartDate" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Fin (opcional, inclusive)</label>
                        <input type="date" class="form-control" id="evEndDate" />
                        <div class="form-text">Si pones fin, será hasta ese día incluido.</div>
                    </div>
                </div>

                <!-- Timed -->
                <div id="timeFields" style="display:none">
                    <div class="mb-3">
                        <label class="form-label">Inicio</label>
                        <input type="datetime-local" class="form-control" id="evStartDT" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Fin (opcional)</label>
                        <input type="datetime-local" class="form-control" id="evEndDT" />
                    </div>
                </div>
            </div>

            <div class="modal-footer d-flex justify-content-between">
                <button type="button" class="btn btn-outline-danger" id="btnDelete" style="visibility:hidden;">Eliminar</button>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" id="btnSave">Guardar</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/interaction/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/daygrid/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/timegrid/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/list/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/locales-all.global.min.js"></script>

    <script>
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        const modalEl = document.getElementById('eventModal');
        const modal = new bootstrap.Modal(modalEl);

        const evId = document.getElementById('evId');
        const evTitle = document.getElementById('evTitle');
        const evAllDay = document.getElementById('evAllDay');

        const allDayFields = document.getElementById('allDayFields');
        const timeFields = document.getElementById('timeFields');

        const evStartDate = document.getElementById('evStartDate');
        const evEndDate = document.getElementById('evEndDate');

        const evStartDT = document.getElementById('evStartDT');
        const evEndDT = document.getElementById('evEndDT');

        const btnSave = document.getElementById('btnSave');
        const btnDelete = document.getElementById('btnDelete');
        const btnNewEvent = document.getElementById('btnNewEvent');

        function pad(n){ return String(n).padStart(2,'0'); }
        function toDateInput(d){
            return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`;
        }
        function toDTInput(d){
            return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
        }
        function addDays(dateStr, days){
            const d = new Date(dateStr + "T00:00:00");
            d.setDate(d.getDate() + days);
            return toDateInput(d);
        }

        function toggleFields(){
            const isAllDay = evAllDay.checked;
            allDayFields.style.display = isAllDay ? '' : 'none';
            timeFields.style.display = isAllDay ? 'none' : '';
        }
        evAllDay.addEventListener('change', toggleFields);

        async function postJson(url, data){
            const res = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify(data)
            });
            if (!res.ok) throw new Error(await res.text());
            return res.headers.get("content-type")?.includes("application/json") ? res.json() : null;
        }

        function openModalForNew(selection){
            evId.value = '';
            evTitle.value = '';
            evAllDay.checked = selection.allDay;
            toggleFields();

            if (selection.allDay){
                // selection.startStr es YYYY-MM-DD
                evStartDate.value = selection.startStr;
                evEndDate.value = ''; // opcional
            } else {
                evStartDT.value = selection.startStr.slice(0,16);
                evEndDT.value = selection.endStr ? selection.endStr.slice(0,16) : '';
            }

            btnDelete.style.visibility = 'hidden';
            modal.show();
        }

        function openModalForEdit(event){
            evId.value = event.id;
            evTitle.value = event.title || '';
            evAllDay.checked = !!event.allDay;
            toggleFields();

            if (event.allDay){
                const s = new Date(event.start);
                evStartDate.value = toDateInput(s);

                // End en FullCalendar allDay es exclusivo -> mostramos inclusive (end-1)
                if (event.end){
                    const e = new Date(event.end);
                    e.setDate(e.getDate() - 1);
                    evEndDate.value = toDateInput(e);
                } else {
                    evEndDate.value = '';
                }
            } else {
                evStartDT.value = toDTInput(new Date(event.start));
                evEndDT.value = event.end ? toDTInput(new Date(event.end)) : '';
            }

            btnDelete.style.visibility = 'visible';
            modal.show();
        }

        const calendarEl = document.getElementById('twiceCalendar');

        const calendar = new FullCalendar.Calendar(calendarEl, {
            locale: 'es',
            firstDay: 1,
            height: 'auto',
            initialView: 'dayGridMonth',
            selectable: true,
            editable: true,
            nowIndicator: true,

            headerToolbar: {
                left: 'prev,next today',
                center: 'title',
                right: 'dayGridMonth,timeGridWeek,timeGridDay,listWeek'
            },

            events: {
                url: '/Calendar/EventsFeed',
                method: 'GET'
            },

            select: function(info){
                openModalForNew(info);
            },

            eventClick: function(info){
                openModalForEdit(info.event);
            },

            eventDrop: async function(info){
                try{
                    await postJson('/Calendar/Move', {
                        id: parseInt(info.event.id),
                        start: info.event.startStr,
                        end: info.event.endStr,
                        allDay: info.event.allDay
                    });
                } catch(e){
                    info.revert();
                    alert('No se pudo mover el evento.');
                }
            },

            eventResize: async function(info){
                try{
                    await postJson('/Calendar/Move', {
                        id: parseInt(info.event.id),
                        start: info.event.startStr,
                        end: info.event.endStr,
                        allDay: info.event.allDay
                    });
                } catch(e){
                    info.revert();
                    alert('No se pudo cambiar la duración.');
                }
            }
        });

        calendar.render();

        btnNewEvent.addEventListener('click', () => {
            // crea uno "hoy"
            openModalForNew({
                allDay: true,
                startStr: toDateInput(new Date()),
                endStr: null
            });
        });

        btnSave.addEventListener('click', async () => {
            const title = (evTitle.value || '').trim();
            if (!title){
                alert('Pon un título.');
                return;
            }

            const isAllDay = evAllDay.checked;

            let start, end = null;

            if (isAllDay){
                start = evStartDate.value;
                const endInclusive = evEndDate.value;

                // si endInclusive existe y es >= start, convertimos a end EXCLUSIVO ( +1 día )
                if (endInclusive && endInclusive >= start){
                    end = addDays(endInclusive, 1);
                }
            } else {
                start = evStartDT.value;
                end = evEndDT.value || null;
            }

            try{
                await postJson('/Calendar/Upsert', {
                    id: evId.value ? parseInt(evId.value) : null,
                    title,
                    start,
                    end,
                    allDay: isAllDay
                });

                modal.hide();
                calendar.refetchEvents();
            } catch(e){
                alert('No se pudo guardar el evento.');
            }
        });

        btnDelete.addEventListener('click', async () => {
            const id = evId.value ? parseInt(evId.value) : null;
            if (!id) return;

            if (!confirm('¿Eliminar este evento?')) return;

            try{
                // DeleteAjax espera un número en el body
                await postJson('/Calendar/DeleteAjax', id);
                modal.hide();
                calendar.refetchEvents();
            } catch(e){
                alert('No se pudo eliminar.');
            }
        });
    </script>
}
