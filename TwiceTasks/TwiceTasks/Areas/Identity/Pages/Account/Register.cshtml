@page
@model TwiceTasks.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Crear cuenta";
}

<style>
    /* ===== Auth pages polish (ties into your light/dark CSS variables) ===== */
    /* Make the card feel like a "hero" instead of a small widget */
    .auth-wrap{
        min-height: 100vh;
        display: flex;
        align-items: center;
        padding: 56px 0;
    }

    .auth-card{
        background: var(--card);
        color: var(--text);
        border: 1px solid var(--border);
        border-radius: 24px;
        box-shadow: 0 24px 60px rgba(0,0,0,.18);
        overflow: hidden;
    }

    /* Slightly larger controls so the form fills more screen */
    .auth-card .form-floating > .form-control{
        height: 3.85rem;
        padding: 1.15rem .95rem;
    }
    .auth-card .form-floating > label{
        padding: 1.05rem .95rem;
    }

    /* Ensure links are always clickable even if something is layered above */
    .auth-card a{ position: relative; z-index: 3; }

    .auth-topbar{
        background: linear-gradient(135deg,
            color-mix(in srgb, var(--link) 38%, transparent),
            color-mix(in srgb, var(--link) 12%, transparent)
        );
        border-bottom: 1px solid var(--border);
    }

    .auth-badge{
        width: 56px;
        height: 56px;
        border-radius: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        background: color-mix(in srgb, var(--card) 82%, transparent);
        border: 1px solid var(--border);
        box-shadow: 0 14px 28px rgba(0,0,0,.14);
    }

    .auth-muted{
        color: color-mix(in srgb, var(--text) 65%, transparent) !important;
    }

    /* Inputs that look crisp on both themes */
    .auth-card .form-control{
        background: color-mix(in srgb, var(--card) 92%, transparent);
        color: var(--text);
        border: 1px solid var(--border);
        border-radius: 14px;
    }

    .auth-card .form-floating > label{
        color: color-mix(in srgb, var(--text) 70%, transparent);
    }

    .auth-card .form-control:focus{
        border-color: color-mix(in srgb, var(--link) 60%, var(--border));
        box-shadow: 0 0 0 .25rem color-mix(in srgb, var(--link) 20%, transparent);
    }

    .auth-card .btn-primary{
        border-radius: 14px;
        padding: 12px 14px;
        font-weight: 700;
    }

    .auth-link{
        color: var(--link);
        text-decoration: none;
        font-weight: 600;
    }
    .auth-link:hover{ text-decoration: underline; }

    .auth-divider{
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 18px 0 0;
    }
    .auth-divider:before,
    .auth-divider:after{
        content: "";
        height: 1px;
        background: var(--border);
        flex: 1;
    }

    /* Make validation feel less "default" */
    .validation-summary-errors{
        border-radius: 14px;
        border: 1px solid color-mix(in srgb, #dc3545 35%, var(--border));
        background: color-mix(in srgb, #dc3545 8%, var(--card));
        padding: 10px 12px;
        margin-bottom: 14px;
    }
    .validation-summary-errors ul{ margin: 0; padding-left: 18px; }

    /* Password reveal button */
    .pw-toggle{
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        border: 0;
        background: transparent;
        color: color-mix(in srgb, var(--text) 70%, transparent);
        padding: 8px;
        border-radius: 10px;
    }
    .pw-toggle:hover{
        background: color-mix(in srgb, var(--border) 35%, transparent);
        color: var(--text);
    }
</style>

<div class="container auth-wrap">
    <div class="row justify-content-center w-100">
        <!-- Wider card so it feels "full page" on desktop -->
        <div class="col-12 col-sm-11 col-md-10 col-lg-8 col-xl-7">

            <div class="card auth-card">
                <div class="auth-topbar p-4 p-md-4 text-center">
                    <div class="auth-badge mb-3" aria-hidden="true">✨</div>
                    <h1 class="h2 fw-bold mb-1">Crear cuenta</h1>
                    <p class="auth-muted mb-0 fs-6">Empieza a organizar tus tareas y notas en minutos.</p>
                </div>

                <div class="card-body p-4 p-md-5 p-lg-5">
                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" novalidate>
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="nombre@ejemplo.com" />
                            <label asp-for="Input.Email">Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3 position-relative">
                            <input asp-for="Input.Password" class="form-control" autocomplete="new-password" placeholder="Contraseña" id="pw" />
                            <label asp-for="Input.Password">Contraseña</label>
                            <button type="button" class="pw-toggle" aria-label="Mostrar u ocultar contraseña" title="Mostrar/Ocultar" data-tt-toggle="pw">
                                <i class="bi bi-eye"></i>
                            </button>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-4 position-relative">
                            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="Confirmar contraseña" id="pw2" />
                            <label asp-for="Input.ConfirmPassword">Confirmar contraseña</label>
                            <button type="button" class="pw-toggle" aria-label="Mostrar u ocultar confirmación" title="Mostrar/Ocultar" data-tt-toggle="pw2">
                                <i class="bi bi-eye"></i>
                            </button>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button id="registerSubmit" type="submit" class="btn btn-primary w-100 btn-lg">
                            Crear cuenta
                        </button>
                    </form>

                    <!-- Keep links OUTSIDE the form so they always navigate (no validation / submit interference) -->
                    <div class="auth-divider auth-muted small">
                        <span>o</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
                        <a class="auth-link" asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@Model.ReturnUrl">
                            ¿Ya tienes cuenta? Inicia sesión
                        </a>
                        <a class="auth-link" asp-area="" asp-controller="Home" asp-action="Index">Volver al inicio</a>
                    </div>

                    @* External logins only if configured *@
                    @if (Model.ExternalLogins?.Count > 0)
                    {
                        <div class="mt-4">
                            <div class="auth-divider auth-muted small"><span>Acceso rápido</span></div>
                            <form method="post" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" class="d-grid gap-2 mt-3">
                                @foreach (var provider in Model.ExternalLogins)
                                {
                                    <button type="submit" class="btn btn-outline-secondary" name="provider" value="@provider.Name">
                                        Continuar con @provider.DisplayName
                                    </button>
                                }
                            </form>
                        </div>
                    }

                    <p class="auth-muted small mt-4 mb-0">
                        Al registrarte, aceptas usar TwiceTasks de forma responsable.
                    </p>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Password show/hide toggles (nice UX, no external deps)
        (function(){
            function toggle(id, btn){
                var input = document.getElementById(id);
                if (!input) return;
                var isPwd = input.getAttribute('type') === 'password';
                input.setAttribute('type', isPwd ? 'text' : 'password');
                var icon = btn.querySelector('i');
                if (icon) {
                    icon.classList.toggle('bi-eye', !isPwd);
                    icon.classList.toggle('bi-eye-slash', isPwd);
                }
            }

            document.querySelectorAll('[data-tt-toggle]').forEach(function(btn){
                btn.addEventListener('click', function(){
                    toggle(btn.getAttribute('data-tt-toggle'), btn);
                });
            });
        })();
    </script>
}
