@page
@model TwiceTasks.Areas.Identity.Pages.Account.Manage.TwoFactorAuthenticationModel
@{
    ViewData["Title"] = "2FA";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
    Layout = "_Layout";
}

<partial name="_StatusMessage" model="Model.StatusMessage" />

<div class="tt-form-section-title">Autenticación en dos pasos (2FA)</div>

<div class="tt-form-section-sub">Añade una capa extra de seguridad a tu cuenta.</div>

<div class="row g-3">
    <div class="col-12 col-lg-6">
        <div class="p-3 rounded-4 border" style="background: color-mix(in srgb, var(--card) 90%, transparent);">
            <div class="fw-semibold mb-1">Estado</div>
            @if (Model.Is2faEnabled)
            {
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-shield-check text-success"></i>
                    <div>2FA está <strong>activado</strong></div>
                </div>
            }
            else
            {
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-shield-exclamation text-warning"></i>
                    <div>2FA está <strong>desactivado</strong></div>
                </div>
                <div class="form-text mt-2">Para activarlo, normalmente se configura un autenticador (Google Authenticator, Microsoft Authenticator, etc.).</div>
            }
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="p-3 rounded-4 border" style="background: color-mix(in srgb, var(--card) 90%, transparent);">
            <div class="fw-semibold mb-1">Códigos de recuperación</div>
            <div class="text-muted">@Model.RecoveryCodesLeft códigos restantes.</div>
            <div class="form-text mt-2">(Esta UI no genera códigos aún. Si los necesitas, lo añadimos en una siguiente iteración.)</div>
        </div>
    </div>
</div>

@if (Model.Is2faEnabled)
{
    <form method="post" asp-page-handler="Disable2fa" class="mt-4">
        <button type="submit" class="btn btn-outline-danger btn-lg">
            <i class="bi bi-shield-x me-2"></i>Desactivar 2FA
        </button>
    </form>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
