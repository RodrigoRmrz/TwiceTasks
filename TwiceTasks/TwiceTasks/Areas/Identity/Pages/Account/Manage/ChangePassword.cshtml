@page
@model TwiceTasks.Areas.Identity.Pages.Account.Manage.ChangePasswordModel
@{
    ViewData["Title"] = "Contraseña";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
    Layout = "_Layout";
}

<partial name="_StatusMessage" model="Model.StatusMessage" />

<div class="tt-form-section-title">Contraseña</div>
<div class="tt-form-section-sub">Actualiza tu contraseña. Usa una combinación segura.</div>

<form id="change-password-form" method="post" class="needs-validation" novalidate>
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

    <div class="row g-3">
        <div class="col-12">
            <label asp-for="Input.OldPassword" class="form-label fw-semibold"></label>
            <div class="position-relative">
                <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" id="tt-old" />
                <button type="button" class="btn btn-sm btn-outline-secondary position-absolute top-50 end-0 translate-middle-y me-2" data-tt-toggle="tt-old" aria-label="Mostrar/Ocultar">
                    <i class="bi bi-eye"></i>
                </button>
            </div>
            <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
        </div>

        <div class="col-12 col-lg-6">
            <label asp-for="Input.NewPassword" class="form-label fw-semibold"></label>
            <div class="position-relative">
                <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" id="tt-new" />
                <button type="button" class="btn btn-sm btn-outline-secondary position-absolute top-50 end-0 translate-middle-y me-2" data-tt-toggle="tt-new" aria-label="Mostrar/Ocultar">
                    <i class="bi bi-eye"></i>
                </button>
            </div>
            <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
        </div>

        <div class="col-12 col-lg-6">
            <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold"></label>
            <div class="position-relative">
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" id="tt-confirm" />
                <button type="button" class="btn btn-sm btn-outline-secondary position-absolute top-50 end-0 translate-middle-y me-2" data-tt-toggle="tt-confirm" aria-label="Mostrar/Ocultar">
                    <i class="bi bi-eye"></i>
                </button>
            </div>
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary btn-lg px-4">Actualizar contraseña</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function(){
            function toggle(id, btn){
                var input = document.getElementById(id);
                if(!input) return;
                var isPwd = input.type === 'password';
                input.type = isPwd ? 'text' : 'password';
                var icon = btn.querySelector('i');
                if(icon){
                    icon.classList.toggle('bi-eye', !isPwd);
                    icon.classList.toggle('bi-eye-slash', isPwd);
                }
            }
            document.querySelectorAll('[data-tt-toggle]').forEach(function(btn){
                btn.addEventListener('click', function(){
                    toggle(btn.getAttribute('data-tt-toggle'), btn);
                });
            });
        })();
    </script>
}
