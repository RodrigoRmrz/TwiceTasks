@using Microsoft.AspNetCore.Identity
@inject SignInManager<TwiceTasks.Models.ApplicationUser> SignInManager
@inject UserManager<TwiceTasks.Models.ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en" class="@((User?.Identity?.IsAuthenticated ?? false) ? "has-sidebar" : "no-sidebar")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TwiceTasks</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TwiceTasks.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <!-- Inicializa el tema (evita flash) -->
    <script>
        (function() {
            try {
                var theme = localStorage.getItem('theme') || 'light';
                document.documentElement.classList.remove('light','dark');
                document.documentElement.classList.add(theme);
            } catch(e) { /* noop */ }
        })();
    </script>

    <style>
        :root {
            --headerH: 0px;
            --controlsH: 78px;
            --sidebarCollapsedW: 65px;
        }
        /* ==============================
                     Variables (light / dark se aplican sobre el elemento html)
                   =============================== */
        html.light {
            --bg: #f4f5f7;
            --text: #1c1c1e;
            --nav: var(--bg);
            --card: #ffffff;
            --border: rgba(0,0,0,0.12);
            --link: #0077ff;
            --toggler-invert: 0;
            --card-bg: var(--card);
            --text-muted: rgba(28, 28, 30, 0.72);
            --shadow: rgba(0,0,0,0.08);
            --shadow-hover: rgba(0,0,0,0.12);
            --surface-hover: rgba(0,0,0,0.04);
            --surface-hover-strong: rgba(0,0,0,0.08);
            --text-placeholder: rgba(28, 28, 30, 0.55);
            --table-stripe: rgba(0,0,0,0.03);
            --today-bg: rgba(0,119,255,0.10);
            --link-hover: #0066dd;
        }

        html.dark {
            --bg: #12141a;
            --text: #e6e6e6;
            --nav: var(--bg);
            --card: #1d1f27;
            --border: rgba(255,255,255,0.18);
            --link: #4da8ff;
            --toggler-invert: 1;
            --card-bg: var(--card);
            --text-muted: rgba(230, 230, 230, 0.74);
            --shadow: rgba(0,0,0,0.55);
            --shadow-hover: rgba(0,0,0,0.7);
            --surface-hover: rgba(255,255,255,0.06);
            --surface-hover-strong: rgba(255,255,255,0.10);
            --text-placeholder: rgba(230, 230, 230, 0.55);
            --table-stripe: rgba(255,255,255,0.04);
            --today-bg: rgba(77,168,255,0.12);
            --link-hover: #8fc7ff;
        }

        /* ==============================
                   Base layout styles
                   =============================== */
        body {
            background: var(--bg);
            color: var(--text);
            font-family: "Segoe UI", Roboto, sans-serif;
            margin: 0;
            padding: 0;
        }

        /* ========== TOP CONTROLS (no visible bar) ========== */
        .top-controls {
            position: fixed;
            top: 14px;
            left: 8px;
            right: 14px;
            z-index: 70;
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 12px;
            pointer-events: none; /* evita “barra” clickeable; solo botones */
        }

        .top-controls > * {
            pointer-events: auto;
        }

        .top-controls-left {
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        .top-controls-right {
            display: flex;
            justify-content: flex-end;
            align-items: center;
        }

        /* Theme toggle button (ya no va “pegado” a una esquina con una barra) */
        .theme-toggle-fab {
            position: static;
            width: 58px;
            height: 58px;
            border-radius: 18px;
            border: 1px solid var(--border);
            background: color-mix(in srgb, var(--card) 86%, transparent);
            color: var(--text);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            box-shadow: 0 14px 28px rgba(0,0,0,.16);
            transition: transform .12s ease, background .12s ease, border-color .12s ease;
        }

        .theme-toggle-fab:hover {
            background: color-mix(in srgb, var(--border) 35%, transparent);
            transform: translateY(-1px);
        }

        .tt-btn {
            height: 46px;
            padding: 0 16px;
            border-radius: 12px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text);
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            font-weight: 600;
            transition: transform .12s ease, background .12s ease, border-color .12s ease;
            white-space: nowrap;
        }

        .tt-btn:hover {
            background: color-mix(in srgb, var(--border) 35%, transparent);
            transform: translateY(-1px);
            color: var(--text);
        }

        .tt-btn-primary {
            background: var(--link);
            border-color: color-mix(in srgb, var(--link) 80%, #000);
            color: #fff;
        }

        .tt-btn-primary:hover {
            background: color-mix(in srgb, var(--link) 88%, #000);
            border-color: color-mix(in srgb, var(--link) 70%, #000);
            color: #fff;
        }

        .tt-project-title {
            font-weight: 900;
            letter-spacing: -1.2px;
            font-size: clamp(2.4rem, 5vw, 4.2rem);
            line-height: 1.05;
            margin: 0 0 18px;
            color: var(--text);
            text-align: center;
        }

        .tt-project-title a {
            color: inherit;
            text-decoration: none;
        }

        /* ========== SIDEBAR (collapsed icons -> expand to show text) ========== */
        .sidebar {
            background-color: var(--bg);
            color: var(--text);
            border-right: 1px solid var(--border);
            width: 65px; /* collapsed width */
            height: calc(100vh - (var(--controlsH) + 10px));
            position: fixed;
            top: calc(var(--controlsH) + 10px);
            left: 0;
            padding: 18px 8px;
            overflow: hidden;
            transition: width 0.22s ease;
            z-index: 50;
        }

            .sidebar:hover {
                width: 240px;
            }

            .sidebar h2 {
                font-size: 1.05rem;
                margin: 6px 0 14px 6px;
                opacity: 0;
                white-space: nowrap;
                transition: opacity .18s;
            }

            .sidebar:hover h2 {
                opacity: 1;
            }

            .sidebar a {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 10px;
                color: var(--text) !important;
                text-decoration: none;
                border-radius: 8px;
                transition: background .15s, color .15s;
                white-space: nowrap;
            }

                .sidebar a i {
                    font-size: 1.12rem;
                    width: 24px;
                    text-align: center;
                }
                /* texto (span) oculto cuando collapsed */
                .sidebar a span {
                    opacity: 0;
                    transition: opacity .18s;
                    transform: translateX(-6px);
                    display: inline-block;
                }

            .sidebar:hover a span {
                opacity: 1;
                transform: translateX(0);
            }

            .sidebar a:hover {
                background: var(--border);
            }

        /* When sidebar hidden (not rendered) ensure main content margin */
        .main-wrapper {
            margin-left: 80px;
            margin-top: calc(var(--controlsH) + 10px);
            padding: 24px;
            transition: margin-left .22s;
        }
        /* when sidebar present and expanded push content */
        .sidebar:hover ~ .main-wrapper {
            margin-left: 260px;
        }

        /* If no sidebar in DOM (user not logged) reduce left margin */
        html.no-sidebar .main-wrapper {
            margin-left: 24px;
        }

        /* ========== Footer ========== */
        footer {
            text-align: center;
            padding: 18px;
            color: var(--text);
        }

        /* small helpers */
        .btn-create {
            margin-top: 8px;
        }

        .sidebar a.active {
            background: var(--border);
            font-weight: 700;
        }

</style>
</head>
<body>
    <!-- Controles superiores flotantes (sin barra visible) -->
    <div class="top-controls" role="banner" aria-label="Controles superiores">
        <div class="top-controls-left">
            <button id="darkModeToggle" class="theme-toggle-fab" aria-label="Activar o desactivar modo oscuro" title="Tema">🌙</button>
        </div>
        <div class="top-controls-right">
            <partial name="_LoginPartial" />
        </div>
    </div>

    @* Sidebar only for authenticated users *@
    @{ 
        var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "");
        var currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? "");
    }

@if (User?.Identity?.IsAuthenticated ?? false)
    {
        <div class="sidebar" role="navigation" aria-label="Dashboard">
            <h2>Mi Dashboard</h2>
            <a class="@(currentController == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index" title="Inicio">
                <i class="bi bi-house-door"></i><span>Inicio</span>
            </a>
            <a class="@(currentController == "Workspaces" ? "active" : "")" asp-controller="Workspaces" asp-action="Index" title="Workspaces">
                <i class="bi bi-kanban"></i><span>Workspaces</span>
            </a>
            <a class="@(currentController == "Pages" ? "active" : "")" asp-controller="Pages" asp-action="Index" title="Notas">
                <i class="bi bi-journal-text"></i><span>Notas</span>
            </a>
            <a class="@(currentController == "Files" ? "active" : "")" asp-controller="Files" asp-action="Index" title="Archivos">
                <i class="bi bi-folder"></i><span>Archivos</span>
            </a>
                    <a class="@(currentController == "Calendar" ? "active" : "")" asp-controller="Calendar" asp-action="Index" title="Calendario">
                <i class="bi bi-calendar-event"></i><span>Calendario</span>
            </a>
</div>
    }


    <!-- MAIN WRAPPER -->
    <div class="main-wrapper">
        @if (currentController == "Home" && currentAction == "Index")
        {
            <h1 class="tt-project-title"><a asp-controller="Home" asp-action="Index">TwiceTasks</a></h1>
        }
        @* Optional carousel section for homepage only. Views can define section "HomeCarousel" *@
        @RenderSection("HomeCarousel", required: false)

        @RenderBody()
    </div>

    <footer>
        © 2025 — TwiceTasks
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- THEME TOGGLE (uses <html> classes 'light' / 'dark' to control CSS variables) -->
    <script>
        (function(){
            const html = document.documentElement;
            const btn = document.getElementById('darkModeToggle');

            // Ensure there is a theme stored
            if (!localStorage.getItem('theme')) localStorage.setItem('theme','light');

            // Apply current theme (script in head already set, but keep this to sync button text)
            const current = localStorage.getItem('theme') || 'light';
            html.classList.remove('light','dark');
            html.classList.add(current);
            if (btn) btn.textContent = html.classList.contains('dark') ? '☀️' : '🌙';

            if (btn) {
                btn.addEventListener('click', function(){
                    const now = html.classList.contains('dark') ? 'light' : 'dark';
                    html.classList.remove('light','dark');
                    html.classList.add(now);
                    localStorage.setItem('theme', now);
                    btn.textContent = now === 'dark' ? '☀️' : '🌙';
                });
            }
        })();
    </script>

    @* RenderScripts section placed at the very end to avoid "section not rendered" error. Views may define the Scripts section. *@
    @RenderSection("Scripts", required: false)
</body>
</html>
