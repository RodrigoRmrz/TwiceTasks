@model TwiceTasks.Models.Collection

<div class="create-wrapper">
    <div class="create-card">
        <h2>Nueva colección</h2>

        <form asp-action="Create" asp-controller="Collection" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Name">Nombre</label>
                <input asp-for="Name" class="form-control" required />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description">Descripción (opcional)</label>
                <textarea asp-for="Description" class="form-control"></textarea>
            </div>

            <div class="buttons">
                <button type="submit" class="btn-save">
                    Crear colección
                </button>

                <a asp-controller="Files" asp-action="Index" class="btn-cancel">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}

<style>
    .create-wrapper {
        display: flex;
        justify-content: center;
        margin-top: 60px;
    }

    .create-card {
        background: var(--card);
        padding: 35px;
        width: 450px;
        border-radius: 14px;
        border: 1px solid var(--border);
        box-shadow: 0 6px 24px var(--shadow);
    }

    h2 {
        text-align: center;
        margin-bottom: 25px;
        color: var(--text);
    }

    .form-group {
        margin-bottom: 18px;
    }

    .buttons {
        display: flex;
        justify-content: space-between;
        margin-top: 20px;
    }

    .btn-save {
        background: var(--link);
        color: #fff;
        padding: 10px 22px;
        border-radius: 12px;
        border: none;
        cursor: pointer;
        font-weight: 600;
    }

    .btn-save:hover {
        background: var(--link-hover);
    }

    .btn-cancel {
        background: transparent;
        color: var(--text);
        padding: 10px 22px;
        border-radius: 12px;
        border: 1px solid var(--border);
        text-decoration: none;
        font-weight: 600;
    }

    .btn-cancel:hover {
        background: var(--surface-hover);
        color: var(--text);
    }
</style>
