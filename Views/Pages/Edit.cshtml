@model TwiceTasks.Models.Page

@{
    var workspaces = ViewBag.Workspaces as List<TwiceTasks.Models.Workspace> ?? new();
    ViewData["Title"] = "Editar nota";
}

<div class="container py-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                <h4 class="mb-0">
                    <i class="bi bi-pencil-square me-2"></i>Editar nota
                </h4>

                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-2"></i>Volver
                </a>
            </div>

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label class="form-label">Título</label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Workspace</label>
                    <select asp-for="WorkspaceId" class="form-select">
                        <option value="">— Sin workspace —</option>
                        @foreach (var ws in workspaces)
                        {
                            <option value="@ws.Id">@ws.Name</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Contenido</label>
                    <textarea asp-for="Content" class="form-control" rows="10"></textarea>
                </div>

                <a asp-action="Index" class="btn btn-primary">
                    <i class="bi bi-check2-circle me-2"></i>Guardar cambios
                </a>

                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger ms-2">
                    <i class="bi bi-trash me-2"></i>Eliminar
                </a>
            </form>

            @* Si ya tienes sección de Tags/Files aquí, mantenla debajo *@
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
