@model TwiceTasks.ViewModels.FilesIndexViewModel

<div class="files-container">
    <div class="files-header">
        <div class="header-left">
            <h1> <i class="bi bi-file-earmark"></i> Mis Archivos</h1>
            <p class="subtitle">Organiza tus documentos en colecciones personalizadas.</p>
        </div>

        <div class="header-right">
            <a asp-controller="Collection" asp-action="Create" class="new-collection-btn">
                <i class="bi bi-folder-plus"></i>
                Nueva colección
            </a>
        </div>
    </div>

    <div class="collection-filter-wrapper">
        <div class="pro-dropdown">
            <button type="button" class="pro-dropbtn" onclick="toggleFilesDropdown()">
                <div class="pro-drop-content">
                    <i class="bi bi-folder2-open"></i>
                    <span class="pro-label">Filtrar por:</span>
                    <span class="pro-selected-name">
                        @(Model.Collections.FirstOrDefault(c => c.Id == Model.SelectedCollectionId)?.Name ?? "Sin Colección")
                    </span>
                </div>
                <i class="bi bi-chevron-down pro-chevron"></i>
            </button>

            <div id="filesCollectionMenu" class="pro-dropdown-menu">
                <div class="menu-search">
                    <i class="bi bi-search"></i>
                    <input type="text" id="menuInput" placeholder="Buscar colección..." onkeyup="filterMenu()">
                </div>

                <div class="menu-items">
                    <a asp-action="Index" asp-controller="Files" asp-route-collectionId="0"
                       class="menu-item @(Model.SelectedCollectionId == 0 ? "active" : "")">
                        <i class="bi bi-grid-fill"></i> Sin Colección
                    </a>

                    <div class="menu-divider">Tus Colecciones</div>

                    @foreach (var col in Model.Collections)
                    {
                        <a asp-action="Index" asp-controller="Files" asp-route-collectionId="@col.Id"
                           class="menu-item @(Model.SelectedCollectionId == col.Id ? "active" : "")">
                            <i class="bi bi-folder"></i> @col.Name
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="upload-box">
        <form method="post" enctype="multipart/form-data" asp-action="Upload" class="upload-form">
            <input type="hidden" name="collectionId" value="@Model.SelectedCollectionId" />
            <label class="upload-area">
                <div class="upload-icon">
                    <i class="bi bi-cloud-arrow-up"></i>
                </div>

                <div class="upload-text">
                    <div class="upload-title">Arrastra o haz clic para subir</div>
                    <div class="upload-subtitle">
                        Se subirá a
                        <strong>@(Model.Collections.FirstOrDefault(c => c.Id == Model.SelectedCollectionId)?.Name ?? "Sin Colección")</strong>
                    </div>
                </div>

                <input type="file" name="file" hidden onchange="this.form.submit()" />
            </label>
        </form>
    </div>

    <div class="files-grid">
        @if (!Model.Files.Any())
        {
            <div class="empty-state">
                <i class="bi bi-folder-x"></i>
                <p>No hay archivos en esta colección.</p>
            </div>
        }
        else
        {
            foreach (var file in Model.Files)
            {
                <div class="file-card">
                    <div class="file-top">
                        <div class="file-icon">
                            <i class="bi bi-file-earmark-text"></i>
                        </div>

                        <div class="file-actions">
                            <a href="@file.FilePath" target="_blank" class="icon-btn view-btn" title="Ver">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@file.Id" class="icon-btn delete-btn" title="Eliminar">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </div>

                    <div class="file-info">
                        <span class="file-name" title="@file.FileName">@file.FileName</span>
                        <span class="file-size">@((file.FileSize / 1024)) KB</span>
                    </div>

                    <form asp-action="MoveToCollection" method="post" class="move-form">
                        <input type="hidden" name="fileId" value="@file.Id" />
                        <input type="hidden" name="currentCollectionId" value="@Model.SelectedCollectionId" />

                        <div class="move-row">
                            <span class="move-label"><i class="bi bi-folder-symlink"></i> Mover a</span>
                            <select name="collectionId" onchange="this.form.submit()" class="move-select" aria-label="Mover a colección">
                                <option value="0" selected="@(file.CollectionId == null)">Sin colección</option>
                                @foreach (var col in Model.Collections)
                                {
                                    <option value="@col.Id" selected="@(file.CollectionId == col.Id)">
                                        @col.Name
                                    </option>
                                }
                            </select>
                        </div>
                    </form>
                </div>
            }
        }
    </div>
</div>

<style>
    .files-container {
        --pro-blue: var(--link);
        --pro-hover: color-mix(in srgb, var(--link) 10%, transparent);
        --pro-border: var(--border);
        --pro-soft: color-mix(in srgb, var(--border) 22%, transparent);
        --pro-text: var(--text);
        --pro-muted: var(--text-muted);
    }

    /* Layout general */
    .files-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 10px 8px 30px;
    }

    .files-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
        gap: 16px;
    }

    .header-left h1 {
        margin: 0;
        font-size: 2.2rem;
        color: var(--pro-text);
        letter-spacing: -0.02em;
    }

    .subtitle {
        margin: 6px 0 0;
        color: var(--pro-muted);
    }

    .new-collection-btn {
        background: var(--pro-blue);
        color: white !important;
        padding: 10px 18px;
        border-radius: 10px;
        font-weight: 650;
        text-decoration: none;
        transition: 0.15s ease;
        display: inline-flex;
        gap: 10px;
        align-items: center;
        box-shadow: 0 10px 22px rgba(35, 131, 226, 0.18);
        white-space: nowrap;
    }

        .new-collection-btn:hover {
            transform: translateY(-1px);
            filter: brightness(0.98);
        }

    /* Selector PRO */
    .collection-filter-wrapper {
        margin: 6px 0 18px;
    }

    .pro-dropdown {
        position: relative;
        display: inline-block;
    }

    .pro-dropbtn {
        background: var(--card);
        border: 1px solid var(--pro-border);
        padding: 10px 14px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        gap: 14px;
        cursor: pointer;
        min-width: 280px;
        justify-content: space-between;
        transition: 0.15s ease;
    }

        .pro-dropbtn:hover {
            border-color: var(--pro-blue);
            background: color-mix(in srgb, var(--card) 92%, transparent);
            box-shadow: 0 8px 18px rgba(0,0,0,0.06);
        }

    .pro-drop-content {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
        color: var(--pro-text);
    }

    .pro-label {
        color: var(--pro-muted);
    }

    .pro-selected-name {
        font-weight: 750;
        color: var(--pro-text);
    }

    .pro-chevron {
        font-size: 12px;
        color: color-mix(in srgb, var(--pro-text) 55%, transparent);
    }

    .pro-dropdown-menu {
        display: none;
        position: absolute;
        top: 112%;
        left: 0;
        background: var(--card);
        min-width: 320px;
        box-shadow: 0 16px 40px rgba(0,0,0,0.15);
        border-radius: 12px;
        border: 1px solid var(--pro-border);
        z-index: 1000;
        padding: 10px;
        overflow: hidden;
    }

    .menu-search {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        background: color-mix(in srgb, var(--border) 14%, transparent);
        border-radius: 10px;
        margin-bottom: 10px;
        border: 1px solid var(--pro-border);
    }

        .menu-search input {
            border: none;
            background: transparent;
            outline: none;
            font-size: 13px;
            width: 100%;
        }

    .menu-items {
        max-height: 260px;
        overflow-y: auto;
        padding-right: 2px;
    }

    .menu-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 10px;
        text-decoration: none;
        color: var(--pro-text);
        font-size: 14px;
        border-radius: 10px;
        transition: 0.1s;
    }

        .menu-item:hover {
            background: var(--pro-hover);
            color: var(--pro-blue);
        }

        .menu-item.active {
            background: color-mix(in srgb, var(--pro-blue) 18%, transparent);
            color: var(--pro-blue);
            font-weight: 650;
        }

    .menu-divider {
        font-size: 11px;
        color: color-mix(in srgb, var(--pro-text) 55%, transparent);
        text-transform: uppercase;
        padding: 14px 10px 6px;
        font-weight: 750;
    }

    .show-menu {
        display: block !important;
        animation: fadeIn 0.18s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Upload */
    .upload-box {
        margin: 10px 0 26px;
    }

    .upload-form {
        display: flex;
        justify-content: center;
    }

    .upload-area {
        width: 100%;
        max-width: 720px;
        padding: 26px 22px;
        border: 2px dashed var(--pro-border);
        border-radius: 16px;
        text-align: left;
        cursor: pointer;
        display: flex;
        gap: 18px;
        align-items: center;
        background: var(--card);
        transition: 0.18s ease;
        box-shadow: 0 10px 26px rgba(0,0,0,0.04);
    }

        .upload-area:hover {
            border-color: var(--pro-blue);
            background: color-mix(in srgb, var(--border) 18%, transparent);
            transform: translateY(-1px);
            box-shadow: 0 18px 40px rgba(35,131,226,0.12);
        }

    .upload-icon {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        background: color-mix(in srgb, var(--pro-blue) 14%, transparent);
        color: var(--pro-blue);
        font-size: 1.4rem;
        flex: 0 0 auto;
    }

    .upload-title {
        font-weight: 800;
        color: var(--pro-text);
        font-size: 15px;
        margin-bottom: 3px;
    }

    .upload-subtitle {
        color: var(--pro-muted);
        font-size: 13px;
    }

    /* Grid de archivos */
    .files-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 18px;
    }

    .empty-state {
        grid-column: 1 / -1;
        text-align: center;
        padding: 45px 15px;
        border: 1px dashed var(--pro-border);
        border-radius: 14px;
        background: var(--card);
        color: var(--pro-muted);
    }

        .empty-state i {
            font-size: 2.2rem;
            color: color-mix(in srgb, var(--pro-text) 45%, transparent);
            display: block;
            margin-bottom: 10px;
        }

    .file-card {
        background: var(--card);
        border: 1px solid var(--pro-border);
        padding: 14px 14px 12px;
        border-radius: 14px;
        transition: 0.18s ease;
        box-shadow: 0 10px 22px rgba(0,0,0,0.03);
    }

        .file-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 16px 34px rgba(0,0,0,0.06);
            border-color: color-mix(in srgb, var(--pro-blue) 35%, var(--pro-border));
        }

    .file-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 10px;
    }

    .file-icon {
        font-size: 2.2rem;
        color: var(--pro-blue);
        margin-bottom: 8px;
    }

    .file-info {
        margin-top: 4px;
    }

    .file-name {
        display: block;
        font-weight: 750;
        font-size: 14px;
        color: var(--pro-text);
        margin-bottom: 4px;
        /* Para que no rompa el layout con nombres largos */
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 100%;
    }

    .file-size {
        font-size: 12px;
        color: var(--pro-muted);
    }

    .file-actions {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .icon-btn {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        display: grid;
        place-items: center;
        border: 1px solid var(--pro-border);
        background: var(--card);
        text-decoration: none;
        transition: 0.12s ease;
    }

        .icon-btn:hover {
            background: color-mix(in srgb, var(--border) 22%, transparent);
            transform: translateY(-1px);
        }

    .view-btn {
        color: color-mix(in srgb, var(--pro-text) 72%, transparent);
    }

    .delete-btn {
        color: #ef4444;
    }

    /* Mover a colección (compacto) */
    .move-form {
        margin-top: 12px;
        padding-top: 10px;
        border-top: 1px solid var(--pro-border);
    }

    .move-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .move-label {
        font-size: 12px;
        color: var(--pro-muted);
        display: inline-flex;
        gap: 8px;
        align-items: center;
        white-space: nowrap;
    }

    .move-select {
        width: 100%;
        max-width: 170px;
        padding: 7px 10px;
        border-radius: 10px;
        border: 1px solid var(--pro-border);
        background: var(--card);
        font-size: 13px;
        color: var(--pro-text);
        outline: none;
        cursor: pointer;
        transition: 0.12s ease;
    }

        .move-select:hover {
            border-color: color-mix(in srgb, var(--pro-blue) 60%, var(--pro-border));
            background: color-mix(in srgb, var(--pro-blue) 10%, transparent);
        }

        .move-select:focus {
            border-color: var(--pro-blue);
            box-shadow: 0 0 0 3px color-mix(in srgb, var(--pro-blue) 28%, transparent);
        }

    /* Responsive */
    @@media (max-width: 640px) {
        .files-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .pro-dropbtn {
            min-width: 100%;
        }

        .upload-area {
            text-align: left;
        }

        .move-select {
            max-width: 100%;
        }
    }
</style>

<script>
    function toggleFilesDropdown() {
        document.getElementById("filesCollectionMenu").classList.toggle("show-menu");
    }

    // Cerrar el menú si se hace clic fuera
    window.addEventListener('click', function(e) {
        if (!document.querySelector('.pro-dropdown').contains(e.target)) {
            document.getElementById("filesCollectionMenu").classList.remove("show-menu");
        }
    });

    // Filtro de búsqueda dentro del menú
    function filterMenu() {
        var input = document.getElementById("menuInput").value.toLowerCase();
        var items = document.getElementsByClassName("menu-item");

        for (var i = 0; i < items.length; i++) {
            var text = items[i].innerText.toLowerCase();
            items[i].style.display = text.includes(input) ? "flex" : "none";
        }
    }
</script>
