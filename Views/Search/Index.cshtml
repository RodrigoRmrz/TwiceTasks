@model IEnumerable<TwiceTasks.Models.Page>

<h2>🔍 Buscador</h2>

<form method="get">
    <input type="text"
           name="q"
           value="@ViewContext.HttpContext.Request.Query["q"]"
           class="form-control mb-3"
           placeholder="Buscar por título o tag..." />
</form>

<ul class="list-group">
@foreach (var p in Model)
{
    <li class="list-group-item">
        <a asp-controller="Pages"
           asp-action="Edit"
           asp-route-id="@p.Id">
            @p.Title
        </a>
        <small class="text-muted">
            —
            @string.Join(", ",
                p.PageTags.Select(pt => pt.Tag.Name))
        </small>
    </li>
}
</ul>
