@model IEnumerable<TwiceTasks.Models.Workspace>
@{
    ViewData["Title"] = "Mis Workspaces";
}
<style>
    body {
        font-family: 'Inter', sans-serif;
    }

    /* ============================================
                             CAROUSEL
            ============================================ */
    .welcome-carousel {
        width: 100%;
        height: 260px;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 10px var(--shadow);
        margin-bottom: 30px;
        background: var(--card);
        position: relative;
    }

        .welcome-carousel img {
            width: 100%;
            height: 260px;
            object-fit: cover;
            filter: brightness(0.75);
        }

    .carousel-caption-custom {
        position: absolute;
        bottom: 20px;
        left: 40px;
        color: var(--text);
    }

        .carousel-caption-custom h2 {
            font-weight: 700;
            margin-bottom: 5px;
        }

    /* ============================================
                         WORKSPACE GRID
            ============================================ */
    .workspace-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 15px;
    }

    .workspace-card {
        background: var(--card);
        border-radius: 12px;
        padding: 18px;
        box-shadow: 0 4px 10px var(--shadow);
        transition: 0.25s;
    }

        .workspace-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 18px var(--shadow-hover);
        }

    .workspace-actions a {
        font-size: 0.85rem;
        padding: 6px 10px;
        border-radius: 6px;
        margin-right: 5px;
    }

    .btn-create {
        margin-bottom: 20px;
        background: var(--link) !important;
        border: 2px solid var(--link) !important;
        color: white !important;
        border-radius: 8px;
        transition: 0.25s;
    }

        .btn-create:hover {
            background: color-mix(in srgb, var(--link) 86%, #000) !important;
        }
</style>

<!-- ======================================================
                        LISTA DE WORKSPACES
====================================================== -->
<h2>Mis Workspaces</h2>

<a class="btn btn-create" asp-action="Create">
    <i class="bi bi-plus-circle"></i> Crear Workspace
</a>

<div class="workspace-grid">
    @foreach (var item in Model)
    {
        <div class="workspace-card">
            <h5>@item.Name</h5>
            <p>@item.Description</p>
            <small>Creado: @item.CreatedAt.ToLocalTime().ToShortDateString()</small>
            <div class="workspace-actions">
                <a class="btn btn-sm btn-outline-primary"
                   asp-controller="Pages"
                   asp-action="Index"
                   asp-route-workspaceId="@item.Id">Ver páginas</a>

                <a class="btn btn-sm btn-outline-secondary"
                   asp-action="Edit"
                   asp-route-id="@item.Id">Editar</a>

                <a class="btn btn-sm btn-outline-danger"
                   asp-action="Delete"
                   asp-route-id="@item.Id">Eliminar</a>
            </div>
        </div>
    }
</div>

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
