@page
@model TwiceTasks.Areas.Identity.Pages.Account.Manage.PersonalDataModel
@{
    ViewData["Title"] = "Datos personales";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
    Layout = "_Layout";
}

<partial name="_StatusMessage" model="Model.StatusMessage" />

<div class="tt-form-section-title">Datos personales</div>
<div class="tt-form-section-sub">Descarga una copia de tu información o elimina tu cuenta.</div>

<div class="row g-3">
    <div class="col-12 col-lg-6">
        <div class="p-3 p-lg-4 rounded-4 border" style="background: color-mix(in srgb, var(--card) 90%, transparent);">
            <div class="fw-semibold mb-1">Descargar datos</div>
            <div class="text-muted mb-3">Obtén un archivo JSON con los datos almacenados de tu perfil.</div>
            <form method="post" asp-page="./DownloadPersonalData">
                <button type="submit" class="btn btn-outline-primary btn-lg">
                    <i class="bi bi-download me-2"></i>Descargar
                </button>
            </form>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="p-3 p-lg-4 rounded-4 border" style="background: color-mix(in srgb, var(--card) 90%, transparent);">
            <div class="fw-semibold mb-1 text-danger">Eliminar cuenta</div>
            <div class="text-muted mb-3">Esta acción es permanente. Se eliminarán tus datos de acceso.</div>
            <a class="btn btn-outline-danger btn-lg" asp-page="./DeletePersonalData">
                <i class="bi bi-trash me-2"></i>Eliminar
            </a>
        </div>
    </div>
</div>
