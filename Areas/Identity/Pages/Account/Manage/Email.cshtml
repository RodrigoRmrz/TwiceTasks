@page
@model TwiceTasks.Areas.Identity.Pages.Account.Manage.EmailModel
@{
    ViewData["Title"] = "Email";
    ViewData["ActivePage"] = ManageNavPages.Email;
    Layout = "_Layout";
}

<partial name="_StatusMessage" model="Model.StatusMessage" />

<div class="tt-form-section-title">Email</div>
<div class="tt-form-section-sub">Cambia el email de tu cuenta. Se usará para iniciar sesión y notificaciones.</div>

<form id="email-form" method="post" class="needs-validation" novalidate>
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

    <div class="row g-3">
        <div class="col-12 col-lg-6">
            <label class="form-label fw-semibold">Email actual</label>
            <div class="input-group">
                <input class="form-control" value="@Model.Email" disabled />
                @if (Model.IsEmailConfirmed)
                {
                    <span class="input-group-text"><i class="bi bi-check-circle-fill text-success"></i><span class="ms-2">Verificado</span></span>
                }
                else
                {
                    <span class="input-group-text"><i class="bi bi-exclamation-circle-fill text-warning"></i><span class="ms-2">Sin verificar</span></span>
                }
            </div>
            <div class="form-text">Si cambias el email, deberás usar el nuevo para entrar.</div>
        </div>

        <div class="col-12 col-lg-6">
            <label asp-for="Input.NewEmail" class="form-label fw-semibold"></label>
            <input asp-for="Input.NewEmail" class="form-control" placeholder="nuevo@email.com" />
            <span asp-validation-for="Input.NewEmail" class="text-danger small"></span>
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary btn-lg px-4">Guardar email</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
